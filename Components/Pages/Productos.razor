    private string _filtroTipo = string.Empty;
    private string _filtroEstado = string.Empty;
    private int paginaActual = 1;
    private int elementosPorPagina = 10;

    private string Busqueda
    {
        get => _busqueda;
        set
        {
            if (_busqueda != value)
            {
                _busqueda = value;
                paginaActual = 1;
            }
        }
    }

    private string FiltroTipo
    {
        get => _filtroTipo;
        set
        {
            if (_filtroTipo != value)
            {
                _filtroTipo = value;
                paginaActual = 1;
            }
        }
    }

    private string FiltroEstado
    {
        get => _filtroEstado;
        set
        {
            if (_filtroEstado != value)
            {
                _filtroEstado = value;
                paginaActual = 1;
            }
        }
    }

    private IEnumerable<Producto> TodosLosFiltrados
    {
        get
        {
            if (productos == null) return Enumerable.Empty<Producto>();

            var resultado = productos.AsEnumerable();

            // Filtro de búsqueda
            if (!string.IsNullOrWhiteSpace(_busqueda))
            {
                resultado = resultado.Where(p =>
                    (p.Nombre?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (p.Referencia?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (p.CodigoBarras?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (p.Descripcion?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false)
                );
            }

            // Filtro por tipo
            if (!string.IsNullOrEmpty(_filtroTipo))
            {
                if (Enum.TryParse<TipoProducto>(_filtroTipo, out var tipo))
                {
                    resultado = resultado.Where(p => p.Tipo == tipo);
                }
            }

            // Filtro por estado
            if (!string.IsNullOrEmpty(_filtroEstado))
            {
                if (bool.TryParse(_filtroEstado, out var activo))
                {
                    resultado = resultado.Where(p => p.Activo == activo);
                }
            }

            return resultado;
        }
    }

    private IEnumerable<Producto> ProductosFiltrados
    {
        get
        {
            return TodosLosFiltrados
                .Skip((paginaActual - 1) * elementosPorPagina)
                .Take(elementosPorPagina);
        }
    }

    private int TotalPaginas => (int)Math.Ceiling((double)TodosLosFiltrados.Count() / elementosPorPagina);

    private void CambiarPagina(int pagina)
    {
        if (pagina >= 1 && pagina <= TotalPaginas)
        {
            paginaActual = pagina;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (productos != null && productos.Any())
        {
            await RenderizarGraficos();
        }
    }

    private async Task CargarProductos()
    {
        productos = await ProductoService.ObtenerTodosAsync();
        StateHasChanged();
    }

    private async Task RenderizarGraficos()
    {
        try
        {
            var categorias = productos!
                .Where(p => !string.IsNullOrEmpty(p.Categoria))
                .GroupBy(p => p.Categoria)
                .OrderByDescending(g => g.Count())
                .Take(5)
                .ToList();

            await JSRuntime.InvokeVoidAsync("eval", $"window.categoriasLabels = {System.Text.Json.JsonSerializer.Serialize(categorias.Select(c => c.Key).ToArray())};");
            await JSRuntime.InvokeVoidAsync("eval", $"window.categoriasData = {System.Text.Json.JsonSerializer.Serialize(categorias.Select(c => c.Count()).ToArray())};");
            
            // Añadir atributos de datos para el script
            await JSRuntime.InvokeVoidAsync("eval", $@"
                if (!document.querySelector('[data-productos]')) {{
                    var elem = document.createElement('div');
                    elem.setAttribute('data-productos', '{productos.Count(p => p.Tipo == TipoProducto.Producto)}');
                    elem.setAttribute('data-servicios', '{productos.Count(p => p.Tipo == TipoProducto.Servicio)}');
                    elem.style.display = 'none';
                    document.body.appendChild(elem);
                }}
            ");
            
            await JSRuntime.InvokeVoidAsync("renderProductCharts");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al renderizar gráficos: {ex.Message}");
        }
    }

    // Modal
