    private async Task ImprimirFacturaVer()
    {
        if (facturaVisualizacion?.Id > 0)
        {
            try
            {
                // Cargar factura completa con cliente y líneas
                var facturaCompleta = await FacturaService.ObtenerPorIdAsync(facturaVisualizacion.Id);
                
                if (facturaCompleta == null || facturaCompleta.Cliente == null)
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Error al cargar los datos de la factura. Asegúrese de que la factura tenga un cliente asignado.");
                    return;
                }

                // Obtener configuración de la empresa específica de la factura
                var config = await ConfiguracionEmpresaService.ObtenerPorEmpresaIdAsync(facturaCompleta.EmpresaId);

                // Generar el PDF para IMPRIMIR
                byte[] pdfBytes = FacturaPdfService.GenerarFacturaPdf(facturaCompleta, facturaCompleta.Cliente, config, paraEmail: false);

                // Convertir a Base64 y usar iframe oculto para imprimir directamente
                string base64Pdf = Convert.ToBase64String(pdfBytes);
                await JSRuntime.InvokeVoidAsync("eval", $@"
                    var byteCharacters = atob('{base64Pdf}');
                    var byteNumbers = new Array(byteCharacters.length);
                    for (var i = 0; i < byteCharacters.length; i++) {{
                        byteNumbers[i] = byteCharacters.charCodeAt(i);
                    }}
                    var byteArray = new Uint8Array(byteNumbers);
                    var blob = new Blob([byteArray], {{type: 'application/pdf'}});
                    var url = URL.createObjectURL(blob);
                    
                    // Crear iframe oculto para imprimir directamente
                    var iframe = document.createElement('iframe');
                    iframe.style.position = 'fixed';
                    iframe.style.right = '0';
                    iframe.style.bottom = '0';
                    iframe.style.width = '0';
                    iframe.style.height = '0';
                    iframe.style.border = 'none';
                    iframe.src = url;
                    document.body.appendChild(iframe);
                    
                    iframe.onload = function() {{
                        setTimeout(function() {{
                            iframe.contentWindow.print();
                        }}, 200);
                    }};
                ");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Error al imprimir factura: {ex.Message}");
            }
        }
    }

    private async Task DescargarDocumentoVer()
    {
        if (facturaVisualizacion != null && !string.IsNullOrEmpty(facturaVisualizacion.DocumentoAdjunto))
        {
            try
            {
                var nombreArchivo = facturaVisualizacion.NombreDocumento?.Replace("'", "\\'") ?? "documento.pdf";
                var tipoDocumento = facturaVisualizacion.TipoDocumento?.Replace("'", "\\'") ?? "application/pdf";
                var documentoBase64 = facturaVisualizacion.DocumentoAdjunto?.Replace("'", "\\'") ?? "";
                
                await JSRuntime.InvokeVoidAsync("eval", $@"
                    (function() {{
                        try {{
                            var base64 = '{documentoBase64}';
                            var nombreArchivo = '{nombreArchivo}';
                            var tipoDocumento = '{tipoDocumento}';
                            
                            var byteCharacters = atob(base64);
                            var byteNumbers = new Array(byteCharacters.length);
                            for (var i = 0; i < byteCharacters.length; i++) {{
                                byteNumbers[i] = byteCharacters.charCodeAt(i);
                            }}
                            var byteArray = new Uint8Array(byteNumbers);
                            var blob = new Blob([byteArray], {{ type: tipoDocumento }});
                            var link = document.createElement('a');
                            link.href = window.URL.createObjectURL(blob);
                            link.download = nombreArchivo;
                            link.click();
                            window.URL.revokeObjectURL(link.href);
                        }} catch (error) {{
                            console.error('Error al descargar:', error);
                            alert('Error al descargar el documento: ' + error.message);
                        }}
                    }})();
                ");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Error al descargar documento: {ex.Message}");
            }
        }
    }

