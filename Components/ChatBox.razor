@using FactioX.Services
@inject IIAService IAService
@inject IChatContextService ChatContextService
@inject IJSRuntime JSRuntime

<div class="chatbox-container @(mostrarChat ? "show" : "")">
    <!-- Bot\u00f3n flotante -->
    @if (!mostrarChat)
    {
        <button class="chatbox-toggle" @onclick="ToggleChat" title="Hablar con Factu">
            <i class="bi bi-robot"></i>
            <span class="chatbox-name">Factu</span>
        </button>
    }

    <!-- Ventana del chat -->
    @if (mostrarChat)
    {
        <div class="chatbox-window">
            <!-- Header -->
            <div class="chatbox-header">
                <div class="d-flex align-items-center">
                    <div class="chatbox-avatar">
                        <i class="bi bi-robot"></i>
                    </div>
                    <div>
                        <strong>Factu</strong>
                        <br />
                        <small class="text-white-50">Asistente Virtual</small>
                    </div>
                </div>
                <button class="btn btn-sm btn-link text-white" @onclick="ToggleChat">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <!-- Mensajes -->
            <div class="chatbox-messages" @ref="mensajesContainer">
                @if (!mensajes.Any())
                {
                    <div class="mensaje-bienvenida">
                        <div class="chatbox-avatar mb-2">
                            <i class="bi bi-robot"></i>
                        </div>
                        <p><strong>¡Hola! Soy Factu 👋</strong></p>
                        <p>Tu asistente virtual de FactioX. Puedo ayudarte con:</p>
                        <ul class="text-start">
                            <li>Consultas sobre facturas y clientes</li>
                            <li>Explicar funcionalidades de la app</li>
                            <li>Consejos de facturación</li>
                            <li>Responder preguntas generales</li>
                        </ul>
                        <p class="mt-2"><small>¿En qué puedo ayudarte hoy?</small></p>
                    </div>
                }

                @foreach (var mensaje in mensajes)
                {
                    <div class="mensaje @(mensaje.Role == "user" ? "mensaje-usuario" : "mensaje-bot")">
                        @if (mensaje.Role == "assistant")
                        {
                            <div class="chatbox-avatar-small">
                                <i class="bi bi-robot"></i>
                            </div>
                        }
                        <div class="mensaje-contenido">
                            @mensaje.Content
                        </div>
                        @if (mensaje.Role == "user")
                        {
                            <div class="user-avatar">
                                <i class="bi bi-person-fill"></i>
                            </div>
                        }
                    </div>
                }

                @if (cargando)
                {
                    <div class="mensaje mensaje-bot">
                        <div class="chatbox-avatar-small">
                            <i class="bi bi-robot"></i>
                        </div>
                        <div class="mensaje-contenido">
                            <div class="typing-indicator">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Input -->
            <div class="chatbox-input">
                <input type="text" 
                       class="form-control" 
                       placeholder="Escribe tu mensaje..." 
                       @bind="mensajeActual"
                       @onkeypress="HandleKeyPress"
                       disabled="@cargando" />
                <button class="btn btn-success" @onclick="EnviarMensaje" disabled="@(cargando || string.IsNullOrWhiteSpace(mensajeActual))">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>

            <!-- Footer info -->
            <div class="chatbox-footer">
                <small class="text-muted">
                    <i class="bi bi-info-circle"></i> Powered by Ollama (Local AI)
                </small>
            </div>
        </div>
    }
</div>

<style>
    .chatbox-container {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
    }

    .chatbox-toggle {
        min-width: 120px;
        height: 60px;
        border-radius: 30px;
        background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%);
        border: none;
        color: white;
        font-size: 24px;
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.4);
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 20px;
    }

    .chatbox-name {
        font-size: 18px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .chatbox-toggle:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 16px rgba(40, 167, 69, 0.6);
    }

    .chatbox-window {
        width: 380px;
        height: 600px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: slideUp 0.3s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .chatbox-header {
        background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%);
        color: white;
        padding: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .chatbox-avatar {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: white;
        color: #28a745;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-right: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .chatbox-avatar-small {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #28a745;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #5cb85c;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .chatbox-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        background: #f8f9fa;
    }

    .mensaje-bienvenida {
        text-align: center;
        padding: 20px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .mensaje {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
        align-items: flex-start;
    }

    .mensaje-usuario {
        flex-direction: row-reverse;
    }

    .mensaje-contenido {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 12px;
        word-wrap: break-word;
        line-height: 1.5;
    }

    .mensaje-bot .mensaje-contenido {
        background: white;
        color: #333;
        border: 1px solid #e0e0e0;
        border-radius: 12px 12px 12px 4px;
    }

    .mensaje-usuario .mensaje-contenido {
        background: #28a745;
        color: white;
        border-radius: 12px 12px 4px 12px;
    }

    .typing-indicator {
        display: flex;
        gap: 4px;
        padding: 8px 0;
    }

    .typing-indicator span {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #28a745;
        animation: typing 1.4s infinite;
    }

    .typing-indicator span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-indicator span:nth-child(3) {
        animation-delay: 0.4s;
    }

    @@keyframes typing {
        0%, 60%, 100% {
            transform: translateY(0);
            opacity: 0.7;
        }
        30% {
            transform: translateY(-10px);
            opacity: 1;
        }
    }

    .chatbox-input {
        display: flex;
        gap: 8px;
        padding: 12px 16px;
        background: white;
        border-top: 1px solid #e0e0e0;
    }

    .chatbox-input input {
        flex: 1;
        border: 1px solid #ddd;
        border-radius: 20px;
        padding: 8px 16px;
    }

    .chatbox-input input:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.15);
    }

    .chatbox-input button {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chatbox-footer {
        padding: 8px 16px;
        text-align: center;
        background: #f8f9fa;
        border-top: 1px solid #e0e0e0;
    }

    @@media (max-width: 768px) {
        .chatbox-window {
            width: 100vw;
            height: 100vh;
            border-radius: 0;
            bottom: 0;
            right: 0;
        }

        .chatbox-toggle {
            bottom: 15px;
            right: 15px;
        }
    }
</style>

@code {
    private bool mostrarChat = false;
    private string mensajeActual = "";
    private bool cargando = false;
    private List<MensajeChat> mensajes = new();
    private ElementReference mensajesContainer;

    protected override void OnInitialized()
    {
        // Configurar el servicio de contexto en IAService
        IAService.SetContextService(ChatContextService);
    }

    private void ToggleChat()
    {
        mostrarChat = !mostrarChat;
        StateHasChanged();
    }

    private async Task EnviarMensaje()
    {
        if (string.IsNullOrWhiteSpace(mensajeActual) || cargando)
            return;

        var mensajeUsuario = mensajeActual.Trim();
        mensajeActual = "";
        cargando = true;

        // Agregar mensaje del usuario
        mensajes.Add(new MensajeChat { Role = "user", Content = mensajeUsuario });
        StateHasChanged();

        await Task.Delay(100);
        await ScrollToBottom();

        try
        {
            // Obtener respuesta
            var respuesta = await IAService.EnviarMensajeAsync(mensajeUsuario, mensajes.Take(mensajes.Count - 1).ToList());

            // Agregar respuesta del bot
            mensajes.Add(new MensajeChat { Role = "assistant", Content = respuesta });
        }
        catch (Exception ex)
        {
            mensajes.Add(new MensajeChat 
            { 
                Role = "assistant", 
                Content = $"Lo siento, ocurrió un error: {ex.Message}" 
            });
        }
        finally
        {
            cargando = false;
            StateHasChanged();
            await Task.Delay(100);
            await ScrollToBottom();
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await EnviarMensaje();
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", 
                "document.querySelector('.chatbox-messages').scrollTop = document.querySelector('.chatbox-messages').scrollHeight");
        }
        catch { }
    }
}
