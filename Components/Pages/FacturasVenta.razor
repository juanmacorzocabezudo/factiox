    private void CambiarProducto(int index, int? productoId)
    {
        var linea = facturaEditando.Lineas[index];
        if (!productoId.HasValue || productoId == 0)
            return;
            
        var producto = productos?.FirstOrDefault(p => p.Id == productoId.Value);
        if (producto != null)
        {
            linea.ProductoId = producto.Id;
            linea.Producto = producto;
            linea.Descripcion = producto.Descripcion ?? producto.Nombre;
            linea.PrecioUnitario = producto.PrecioUnitario;
            linea.IVA = producto.IVA;
        }
        
        CalcularTotalModal();
    }

    private void CalcularTotalModal()
    {
        // Calcular importes de cada línea primero
        foreach (var linea in facturaEditando.Lineas)
        {
            linea.CalcularImportes();
        }
        
        // Calcular subtotal de líneas (ya se calcula automáticamente en la propiedad)
        var subtotal = facturaEditando.Subtotal;
        
        // Calcular base imponible
        facturaEditando.BaseImponible = subtotal - facturaEditando.DescuentosGenerales + facturaEditando.RecargosGenerales;
        
        // Calcular importe IVA (ya se calcula automáticamente en TotalIVA)
        facturaEditando.ImporteIVA = facturaEditando.TotalIVA;
        
        // Calcular retención
        facturaEditando.ImporteRetencion = facturaEditando.BaseImponible * (facturaEditando.PorcentajeRetencion / 100);
        
        // Calcular total
        facturaEditando.Total = facturaEditando.BaseImponible + facturaEditando.ImporteIVA + facturaEditando.CargosAdicionales - facturaEditando.ImporteRetencion;
        
        StateHasChanged();
    }

    // Métodos para acciones de factura
    private async Task ImprimirFactura()
    {
        if (facturaEditando?.Id > 0)
        {
            try
            {
                // Cargar factura completa con cliente y líneas
                var facturaCompleta = await FacturaService.ObtenerPorIdAsync(facturaEditando.Id);
                
                if (facturaCompleta == null || facturaCompleta.Cliente == null)
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Error al cargar los datos de la factura. Asegúrese de que la factura tenga un cliente asignado.");
                    return;
                }

                var config = await ConfiguracionEmpresaService.ObtenerConfiguracionAsync();

                // Generar el PDF para IMPRIMIR
                byte[] pdfBytes = FacturaPdfService.GenerarFacturaPdf(facturaCompleta, facturaCompleta.Cliente, config, paraEmail: false);

                // Convertir a Base64 y usar iframe oculto para imprimir directamente
                string base64Pdf = Convert.ToBase64String(pdfBytes);
                await JSRuntime.InvokeVoidAsync("eval", $@"
                    var byteCharacters = atob('{base64Pdf}');
                    var byteNumbers = new Array(byteCharacters.length);
                    for (var i = 0; i < byteCharacters.length; i++) {{
                        byteNumbers[i] = byteCharacters.charCodeAt(i);
                    }}
                    var byteArray = new Uint8Array(byteNumbers);
                    var blob = new Blob([byteArray], {{type: 'application/pdf'}});
                    var url = URL.createObjectURL(blob);
                    
                    // Crear iframe oculto para imprimir directamente
                    var iframe = document.createElement('iframe');
                    iframe.style.position = 'fixed';
                    iframe.style.right = '0';
                    iframe.style.bottom = '0';
                    iframe.style.width = '0';
                    iframe.style.height = '0';
                    iframe.style.border = 'none';
                    iframe.src = url;
                    document.body.appendChild(iframe);
                    
                    iframe.onload = function() {{
                        setTimeout(function() {{
                            iframe.contentWindow.focus();
                            iframe.contentWindow.print();
                        }}, 250);
                    }};
                ");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Error al imprimir: {ex.Message}");
            }
        }
    }

    private async Task EnviarEmail()
    {
        if (facturaEditando?.Id > 0)
        {
            try
            {
                // Cargar factura completa con cliente
                var facturaCompleta = await FacturaService.ObtenerPorIdAsync(facturaEditando.Id);
                
                if (facturaCompleta == null || facturaCompleta.Cliente == null)
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Error: La factura no tiene un cliente asignado.");
                    return;
                }

                // Verificar que el cliente tenga email
                if (string.IsNullOrEmpty(facturaCompleta.Cliente.Email))
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Error: El cliente no tiene un email configurado en su ficha.");
                    return;
                }

                var config = await ConfiguracionEmpresaService.ObtenerConfiguracionAsync();

                // Generar PDF para email
                byte[] pdfBytes = FacturaPdfService.GenerarFacturaPdf(facturaCompleta, facturaCompleta.Cliente, config, paraEmail: true);

                // Preparar email
                var nombreEmpresa = config?.NombreEmpresa ?? "FactioX";
                var asunto = $"Factura {facturaCompleta.NumeroFactura} - {nombreEmpresa}";
                
                // Construir cuerpo del email
                var cuerpoBuilder = new System.Text.StringBuilder();
                cuerpoBuilder.AppendLine("<html>");
                cuerpoBuilder.AppendLine("<body style='font-family: Arial, sans-serif;'>");
                cuerpoBuilder.AppendLine($"<h2>Factura {facturaCompleta.NumeroFactura}</h2>");
                cuerpoBuilder.AppendLine($"<p>Estimado/a {facturaCompleta.Cliente.Nombre},</p>");
                cuerpoBuilder.AppendLine($"<p>Adjuntamos la factura <strong>{facturaCompleta.NumeroFactura}</strong> con fecha {facturaCompleta.FechaEmision:dd/MM/yyyy}.</p>");
                cuerpoBuilder.AppendLine($"<p><strong>Importe total:</strong> {facturaCompleta.Total:C2}</p>");
                cuerpoBuilder.AppendLine("<p>Para cualquier consulta, no dude en contactarnos.</p>");
                cuerpoBuilder.AppendLine("<br/>");
                cuerpoBuilder.AppendLine($"<p>Atentamente,<br/>{nombreEmpresa}</p>");
                if (!string.IsNullOrEmpty(config?.Email))
                {
                    cuerpoBuilder.AppendLine($"<p style='color: #666; font-size: 12px;'>Email: {config.Email}</p>");
                }
                if (!string.IsNullOrEmpty(config?.Telefono))
                {
                    cuerpoBuilder.AppendLine($"<p style='color: #666; font-size: 12px;'>Teléfono: {config.Telefono}</p>");
                }
                cuerpoBuilder.AppendLine("</body>");
                cuerpoBuilder.AppendLine("</html>");
                var cuerpo = cuerpoBuilder.ToString();

                var nombreArchivo = $"Factura_{facturaCompleta.NumeroFactura.Replace("/", "-")}_{DateTime.Now:yyyyMMdd}.pdf";

                // Usar EmailSecundario en CC si existe
                string? cc = !string.IsNullOrEmpty(facturaCompleta.Cliente.EmailSecundario) 
                    ? facturaCompleta.Cliente.EmailSecundario 
                    : null;

                // Enviar email
                await EmailService.EnviarEmailConAdjunto(
                    facturaCompleta.Cliente.Email,
                    asunto,
                    cuerpo,
                    pdfBytes,
                    nombreArchivo,
                    cc
                );

                await JSRuntime.InvokeVoidAsync("alert", $"Factura enviada correctamente a {facturaCompleta.Cliente.Email}");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Error al enviar email: {ex.Message}\n\nAsegúrate de tener configurado el servidor SMTP en appsettings.json");
            }
        }
    }

