@page "/productos/nuevo"
@page "/productos/editar/{id:int}"
@using FactioX.Models
@using FactioX.Services
@inject IProductoService ProductoService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>FactioX</PageTitle>

<div class="container">
    <div class="row mb-3">
        <div class="col">
            <h1>@(Id.HasValue ? "Editar" : "Nuevo") Producto/Servicio</h1>
        </div>
    </div>

    <EditForm Model="@producto" OnValidSubmit="GuardarProducto">
        <DataAnnotationsValidator />
        
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label for="nombre" class="form-label">Nombre *</label>
                        <InputText id="nombre" class="form-control" @bind-Value="producto.Nombre" />
                        <ValidationMessage For="@(() => producto.Nombre)" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label for="tipo" class="form-label">Tipo *</label>
                        <InputSelect id="tipo" class="form-select" @bind-Value="producto.Tipo">
                            <option value="@TipoProducto.Producto">Producto</option>
                            <option value="@TipoProducto.Servicio">Servicio</option>
                        </InputSelect>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label for="descripcion" class="form-label">Descripción</label>
                        <InputTextArea id="descripcion" class="form-control" rows="3" @bind-Value="producto.Descripcion" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label for="precio" class="form-label">Precio Unitario *</label>
                        <InputNumber id="precio" class="form-control" @bind-Value="producto.PrecioUnitario" />
                        <ValidationMessage For="@(() => producto.PrecioUnitario)" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label for="iva" class="form-label">IVA (%) *</label>
                        <InputNumber id="iva" class="form-control" @bind-Value="producto.IVA" />
                        <ValidationMessage For="@(() => producto.IVA)" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label d-block">Estado</label>
                        <div class="form-check form-switch">
                            <InputCheckbox id="activo" class="form-check-input" @bind-Value="producto.Activo" />
                            <label class="form-check-label" for="activo">
                                @(producto.Activo ? "Activo" : "Inactivo")
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Guardar
            </button>
            <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                <i class="bi bi-x-circle"></i> Cancelar
            </button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private Producto producto = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var productoExistente = await ProductoService.ObtenerPorIdAsync(Id.Value);
            if (productoExistente != null)
            {
                producto = productoExistente;
            }
            else
            {
                Navigation.NavigateTo("/productos");
            }
        }
    }

    private async Task GuardarProducto()
    {
        if (Id.HasValue)
        {
            await ProductoService.ActualizarAsync(Id.Value, producto);
        }
        else
        {
            await ProductoService.CrearAsync(producto);
        }
        
        Navigation.NavigateTo("/productos");
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/productos");
    }
}
