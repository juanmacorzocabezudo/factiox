@inherits LayoutComponentBase

<div class="page">
    <header class="top-navbar">
        <NavMenu />
    </header>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>

    <footer class="app-footer">
        <div class="container-fluid py-2">
            <div class="row g-3">
                <!-- Sección Izquierda: Logo y Marca -->
                <div class="col-lg-4 col-md-6">
                    <div class="footer-section">
                        <div class="footer-logo-container mb-1">
                            <img src="LogoFactioxFIN.png" alt="FactioX" class="footer-logo" />
                            <span class="footer-brand ms-2">FactioX</span>
                        </div>
                        <p class="footer-tagline mb-1">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            Gestión Integral de Facturación
                        </p>
                        <p class="footer-description">
                            Sistema profesional de facturación electrónica y gestión empresarial.
                        </p>
                    </div>
                </div>

                <!-- Sección Central: Información Legal -->
                <div class="col-lg-4 col-md-6">
                    <div class="footer-section">
                        <h6 class="footer-heading mb-2">
                            <i class="bi bi-shield-check me-2"></i>
                            Información Legal
                        </h6>
                        <ul class="footer-links-list">
                            <li>
                                <a href="/proteccion-datos" class="footer-link">
                                    <i class="bi bi-file-text me-2"></i>
                                    Protección de Datos (RGPD)
                                </a>
                            </li>
                            <li>
                                <a href="/politica-cookies" class="footer-link">
                                    <i class="bi bi-cookie me-2"></i>
                                    Política de Cookies
                                </a>
                            </li>
                            <li class="mt-2">
                                <small class="text-muted">
                                    <i class="bi bi-building me-2"></i>
                                    Cumplimiento normativa española
                                </small>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Sección Derecha: Contacto y Copyright -->
                <div class="col-lg-4 col-md-12">
                    <div class="footer-section">
                        <h6 class="footer-heading mb-2">
                            <i class="bi bi-info-circle me-2"></i>
                            Acerca de
                        </h6>
                        <p class="footer-description mb-1">
                            <i class="bi bi-code-slash me-2" style="font-size: 0.85rem;"></i>
                            Versión Beta 09072026
                        </p>
                        <p class="footer-description mb-2">
                            <i class="bi bi-geo-alt me-2"></i>
                            Desarrollado en España
                        </p>
                        <div class="footer-copyright">
                            <i class="bi bi-c-circle me-1"></i>
                            &copy; @DateTime.Now.Year FactioX
                            <br />
                            <small>Todos los derechos reservados</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Línea divisoria -->
            <hr class="footer-divider my-2" />
        </div>
    </footer>

    <!-- ChatBox de IA -->
    <ChatBox @rendermode="InteractiveServer" />
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
