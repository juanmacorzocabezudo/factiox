    private async Task CargarArchivoOcr(InputFileChangeEventArgs e)
    {
        try
        {
            var archivo = e.File;
            
            // Reducir límite a 3MB para evitar problemas de memoria en Ollama
            if (archivo.Size > 3 * 1024 * 1024)
            {
                await JSRuntime.InvokeVoidAsync("alert", "El archivo es demasiado grande. Máximo 3MB. Por favor, reduce el tamaño de la imagen antes de subirla.");
                return;
            }

            using var ms = new MemoryStream();
            await archivo.OpenReadStream(3 * 1024 * 1024).CopyToAsync(ms);
            var bytes = ms.ToArray();
            
            // Advertir si la imagen es grande
            var tamañoKB = bytes.Length / 1024;
            if (tamañoKB > 1000)
            {
                Console.WriteLine($"Advertencia: Imagen grande ({tamañoKB}KB). Considera usar imágenes de 500KB-1MB para mejor rendimiento.");
            }
            
            imagenBase64 = Convert.ToBase64String(bytes);
            imagenPreview = $"data:{archivo.ContentType};base64,{imagenBase64}";
            imagenCargada = true;
            facturaExtraida = null;
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al cargar el archivo: {ex.Message}");
        }
    }

    private async Task ExtraerDatosOcr()
    {
        if (string.IsNullOrEmpty(imagenBase64))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Primero debes cargar una imagen.");
            return;
        }

        procesandoOcr = true;
        try
        {
            facturaExtraida = await InvoiceOcrService.ExtraerDatosFacturaAsync(imagenBase64);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al extraer datos: {ex.Message}");
        }
        finally
