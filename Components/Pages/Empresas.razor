@page "/empresas"
@using FactioX.Models
@using FactioX.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IEmpresaService EmpresaService
@inject IDatosPruebaService DatosPruebaService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>FactioX</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-end align-items-center mb-4">
        @if (AuthService.Rol == Roles.SuperAdministrador)
        {
            <button class="btn btn-primary" @onclick="NuevaEmpresa">
                <i class="bi bi-plus-circle"></i> Nueva Empresa
            </button>
        }
    </div>

    @if (empresas != null)
    {
        <div class="row">
            @foreach (var empresa in empresas)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100" @ondblclick="() => EditarEmpresa(empresa.Id)" style="cursor: pointer;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title mb-0">@empresa.NombreComercial</h5>
                                <span class="badge @(empresa.Activa ? "bg-success" : "bg-secondary")">
                                    @(empresa.Activa ? "Activa" : "Inactiva")
                                </span>
                            </div>
                            
                            <p class="card-text">
                                <small class="text-muted">
                                    <i class="bi bi-link-45deg"></i> Slug: <strong>@empresa.Slug</strong>
                                </small>
                            </p>
                            
                            <p class="card-text">
                                <small>
                                    <i class="bi bi-calendar"></i> Alta: @empresa.FechaAlta.ToString("dd/MM/yyyy")
                                </small>
                            </p>
                            
                            <div class="mb-3">
                                <span class="badge bg-primary">@empresa.PlanSuscripcion</span>
                            </div>
                            
                            <ul class="list-unstyled small">
                                <li><i class="bi bi-people"></i> Máx. Usuarios: @(empresa.MaxUsuarios?.ToString() ?? "∞")</li>
                            </ul>
                        </div>
                        @if (AuthService.Rol == Roles.SuperAdministrador)
                        {
                            <div class="card-footer bg-transparent">
                                <div class="btn-group w-100">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => EditarEmpresa(empresa.Id)">
                                        <i class="bi bi-pencil"></i> Editar
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarEmpresa(empresa.Id)">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p><em>Cargando...</em></p>
    }
</div>

<!-- Modal de Empresa -->
@if (mostrarModal)
{
    <div class="modal fade" id="empresaModal" tabindex="-1" aria-labelledby="empresaModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <EditForm Model="@empresaActual" OnValidSubmit="GuardarEmpresa">
                    <DataAnnotationsValidator />
                    
                    <!-- Header fijo con botones -->
                    <div class="modal-header sticky-top bg-white" style="z-index: 1050;">
                        <h5 class="modal-title" id="empresaModalLabel">@tituloModal</h5>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Guardar
                            </button>
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModal">
                                <i class="bi bi-x-circle"></i> Cancelar
                            </button>
                        </div>
                    </div>
                    
                    <div class="modal-body">
                        <!-- Datos Básicos -->
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <h6 class="mb-0">Datos Básicos</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Nombre Comercial *</label>
                                        <InputText class="form-control" @bind-Value="empresaActual.NombreComercial" />
                                        <ValidationMessage For="@(() => empresaActual.NombreComercial)" />
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Slug (URL amigable) *</label>
                                        <InputText class="form-control" @bind-Value="empresaActual.Slug" placeholder="mi-empresa" />
                                        <ValidationMessage For="@(() => empresaActual.Slug)" />
                                        <small class="text-muted">Solo letras minúsculas, números y guiones</small>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label">Estado</label>
                                        <div class="form-check form-switch mt-2">
                                            <InputCheckbox class="form-check-input" @bind-Value="empresaActual.Activa" id="switchActiva" />
                                            <label class="form-check-label" for="switchActiva">
                                                @(empresaActual.Activa ? "Activa" : "Inactiva")
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (!esEdicion)
                        {
                            <!-- Opción de generar datos de prueba (solo al crear) -->
                            <div class="card mb-3 border-info">
                                <div class="card-header bg-info bg-opacity-10">
                                    <div class="form-check">
                                        <InputCheckbox class="form-check-input" @bind-Value="generarDatosPrueba" id="checkGenerarDatos" />
                                        <label class="form-check-label fw-bold" for="checkGenerarDatos">
                                            <i class="bi bi-database-fill-add"></i> Generar Datos de Prueba
                                        </label>
                                    </div>
                                </div>
                                @if (generarDatosPrueba)
                                {
                                    <div class="card-body">
                                        <div class="alert alert-info mb-0">
                                            <h6><i class="bi bi-info-circle"></i> Datos que se generarán automáticamente:</h6>
                                            <ul class="mb-0">
                                                <li>✅ <strong>Configuración de empresa</strong> con datos básicos</li>
                                                <li>✅ <strong>5 Clientes</strong> (particulares y empresas)</li>
                                                <li>✅ <strong>3 Proveedores</strong> con información completa</li>
                                                <li>✅ <strong>8 Productos/Servicios</strong> listos para usar</li>
                                                <li>✅ <strong>3 Formas de pago</strong> personalizadas (Bizum, PayPal, Stripe)</li>
                                                <li>✅ <strong>3 Presupuestos</strong> de ejemplo (pendientes/aceptados)</li>
                                                <li>✅ <strong>4 Facturas de venta</strong> con diferentes estados de pago</li>
                                                <li>✅ <strong>2 Facturas de compra</strong> con proveedores</li>
                                            </ul>
                                            <div class="mt-3">
                                                <small class="text-muted">
                                                    <i class="bi bi-lightbulb"></i> <strong>Perfecto para:</strong> Demos, formación, pruebas y evaluación del sistema sin necesidad de crear datos manualmente.
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Plan y Límites -->
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <h6 class="mb-0">Plan y Límites</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Plan de Suscripción *</label>
                                        <InputSelect class="form-select" @bind-Value="empresaActual.PlanSuscripcion">
                                            <option value="Basico">Básico</option>
                                            <option value="Profesional">Profesional</option>
                                            <option value="Empresarial">Empresarial</option>
                                            <option value="Premium">Premium</option>
                                        </InputSelect>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Máximo de Usuarios</label>
                                        <InputNumber class="form-control" @bind-Value="empresaActual.MaxUsuarios" placeholder="Dejar vacío para ilimitado" />
                                        <small class="text-muted">Dejar vacío para usuarios ilimitados</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (esEdicion)
                        {
                            <!-- Información Adicional (solo en edición) -->
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Información</h6>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Fecha de Alta</label>
                                            <input type="text" class="form-control" readonly value="@empresaActual.FechaAlta.ToString("dd/MM/yyyy HH:mm")" />
                                        </div>
                                        @if (empresaActual.FechaBaja.HasValue)
                                        {
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Fecha de Baja</label>
                                                <input type="text" class="form-control" readonly value="@empresaActual.FechaBaja.Value.ToString("dd/MM/yyyy HH:mm")" />
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Empresa>? empresas;
    
    // Modal
    private bool mostrarModal = false;
    private bool esEdicion = false;
    private Empresa empresaActual = new();
    private bool generarDatosPrueba = false;
    private bool generandoDatos = false;
    private string tituloModal => esEdicion ? "Editar Empresa" : "Nueva Empresa";

    protected override async Task OnInitializedAsync()
    {
        await CargarEmpresas();
    }

    private async Task CargarEmpresas()
    {
        empresas = await EmpresaService.ObtenerTodasAsync();
        StateHasChanged();
    }

    private async Task NuevaEmpresa()
    {
        empresaActual = new Empresa
        {
            Activa = true,
            PlanSuscripcion = "Basico",
            MaxUsuarios = 5,
            FechaAlta = DateTime.Now
        };
        esEdicion = false;
        generarDatosPrueba = false;
        mostrarModal = true;
        StateHasChanged();
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('empresaModal')).show()");
    }

    private async Task EditarEmpresa(int id)
    {
        var empresa = empresas?.FirstOrDefault(e => e.Id == id);
        if (empresa != null)
        {
            empresaActual = new Empresa
            {
                Id = empresa.Id,
                NombreComercial = empresa.NombreComercial,
                Slug = empresa.Slug,
                Activa = empresa.Activa,
                FechaAlta = empresa.FechaAlta,
                FechaBaja = empresa.FechaBaja,
                PlanSuscripcion = empresa.PlanSuscripcion,
                MaxUsuarios = empresa.MaxUsuarios
            };
            esEdicion = true;
            mostrarModal = true;
            StateHasChanged();
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('empresaModal')).show()");
        }
    }

    private async Task GuardarEmpresa()
    {
        try
        {
            if (esEdicion)
            {
                await EmpresaService.ActualizarAsync(empresaActual.Id, empresaActual);
                await JSRuntime.InvokeVoidAsync("alert", "Empresa actualizada correctamente");
            }
            else
            {
                // Crear la empresa
                var empresaCreada = await EmpresaService.CrearAsync(empresaActual);
                
                // Generar datos de prueba si se solicitó
                if (generarDatosPrueba)
                {
                    generandoDatos = true;
                    StateHasChanged();
                    
                    await JSRuntime.InvokeVoidAsync("alert", "Empresa creada. Generando datos de prueba... (esto puede tardar unos segundos)");
                    
                    await DatosPruebaService.GenerarDatosPruebaAsync(empresaCreada.Id);
                    
                    generandoDatos = false;
                    await JSRuntime.InvokeVoidAsync("alert", "✅ ¡Empresa creada con datos de prueba exitosamente!\n\nSe han generado clientes, proveedores, productos, presupuestos y facturas de ejemplo.");
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Empresa creada correctamente");
                }
            }

            await CerrarModal();
            await CargarEmpresas();
        }
        catch (Exception ex)
        {
            generandoDatos = false;
            Console.WriteLine($"Error al guardar empresa: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", $"Error al guardar: {ex.Message}");
        }
    }

    private async Task CerrarModal()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('empresaModal'))?.hide()");
            await Task.Delay(200); // Esperar a que el modal se cierre
        }
        catch { }
        
        mostrarModal = false;
        empresaActual = new();
        generarDatosPrueba = false;
        generandoDatos = false;
        StateHasChanged();
    }

    private async Task EliminarEmpresa(int id)
    {
        var confirmado = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de desactivar esta empresa? Los usuarios no podrán acceder.");
        if (confirmado)
        {
            try
            {
                await EmpresaService.EliminarAsync(id);
                await JSRuntime.InvokeVoidAsync("alert", "Empresa desactivada correctamente");
                await CargarEmpresas();
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Error al desactivar empresa: {ex.Message}");
            }
        }
    }
}
