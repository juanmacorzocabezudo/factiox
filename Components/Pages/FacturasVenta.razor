    private async Task ExportarXMLFirmado()
    {
        try
        {
            if (facturaEditando?.Id == 0)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Debe guardar la factura antes de exportarla.");
                return;
            }
            
            // Obtener configuración de la empresa actual
            var empresaId = await TenantService.GetEmpresaIdAsync();
            if (!empresaId.HasValue)
            {
                await JSRuntime.InvokeVoidAsync("alert", "No se pudo obtener la empresa activa.");
                return;
            }
            
            var configuracion = await ConfiguracionEmpresaService.ObtenerPorEmpresaIdAsync(empresaId.Value);
            if (configuracion == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "No se encontró la configuración de la empresa.");
                return;
            }
            
            // Verificar que la empresa tenga certificado configurado
            if (string.IsNullOrWhiteSpace(configuracion.CertificadoRuta))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Esta empresa no tiene un certificado digital configurado.\n\nPor favor, configure el certificado en la página de Configuración antes de firmar facturas.");
                return;
            }
            
            if (string.IsNullOrWhiteSpace(configuracion.CertificadoPassword))
            {
                await JSRuntime.InvokeVoidAsync("alert", "El certificado de la empresa no tiene contraseña configurada.\n\nPor favor, complete la configuración del certificado.");
                return;
            }
            
            // Verificar que el archivo del certificado existe
            if (!File.Exists(configuracion.CertificadoRuta))
            {
                await JSRuntime.InvokeVoidAsync("alert", $"No se encuentra el archivo del certificado en:\n{configuracion.CertificadoRuta}\n\nPor favor, verifique la ruta en la configuración de la empresa.");
                return;
            }
            
            // Generar XML sin firma
            var xmlSinFirmar = await FacturaEService.GenerarFacturaEXmlAsync(facturaEditando.Id);
            
            // Firmar XML con el certificado de la empresa
            var xmlFirmado = FirmaDigitalService.FirmarXml(xmlSinFirmar, configuracion.CertificadoRuta, configuracion.CertificadoPassword);
            
            // Convertir a bytes y descargar
            var xmlBytes = System.Text.Encoding.UTF8.GetBytes(xmlFirmado);
            var base64 = Convert.ToBase64String(xmlBytes);
            
            var nombreArchivo = $"Factura_{facturaEditando.NumeroFactura.Replace("/", "-")}_FIRMADA_{DateTime.Now:yyyyMMdd}.xml";
            await JSRuntime.InvokeVoidAsync("downloadFile", nombreArchivo, base64, "text/xml");
            
            await JSRuntime.InvokeVoidAsync("alert", "Factura firmada digitalmente y exportada correctamente.");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al firmar y exportar la factura: {ex.Message}");
        }
    }

