                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalDetallePago"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <strong><i class="bi bi-calendar-event"></i> Información General</strong>
                                </div>
                                <div class="card-body">
                                    <p><strong>Fecha de Pago:</strong> @pagoDetalle.FechaPago.ToString("dd/MM/yyyy")</p>
                                    <p><strong>Forma de Pago:</strong> <span class="badge bg-success">@pagoDetalle.FormaPago</span></p>
                                    <p><strong>Importe:</strong> <span class="h4 text-success">@pagoDetalle.Importe.ToString("C2")</span></p>
                                    <p><strong>Referencia:</strong> @pagoDetalle.Referencia</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <strong><i class="bi bi-file-text"></i> Factura Relacionada</strong>
                                </div>
                                <div class="card-body">
                                    <p><strong>Número:</strong> @pagoDetalle.Factura?.NumeroFactura</p>
                                    <p><strong>Cliente:</strong> @pagoDetalle.Factura?.Cliente?.Nombre</p>
                                    <p><strong>Total Factura:</strong> @pagoDetalle.Factura?.Total.ToString("C2")</p>
                                    <p><strong>Estado:</strong> <span class="badge @ObtenerClaseEstado(pagoDetalle.Factura?.Estado ?? EstadoFactura.Borrador)" style="@ObtenerEstiloEstado(pagoDetalle.Factura?.Estado ?? EstadoFactura.Borrador)">@pagoDetalle.Factura?.Estado</span></p>
                                </div>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(pagoDetalle.Notas))
                    {
                        <div class="card">
                            <div class="card-header bg-light">
                                <strong><i class="bi bi-sticky"></i> Notas / Observaciones</strong>
                            </div>
                            <div class="card-body">
                                <p>@pagoDetalle.Notas</p>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn" style="color: #28a745; border-color: #28a745;" @onclick="() => ExportarPagoXML(pagoDetalle.Id)">
                        <i class="bi bi-file-earmark-code"></i> Exportar XML
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModalDetallePago">
                        <i class="bi bi-x-circle"></i> Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" style="z-index: 1055;"></div>
}

@code {
    private List<Cliente>? clientes;
    private List<PagoFactura>? pagosCliente;
    private List<Producto>? productosDisponibles;
    private string _busqueda = string.Empty;
    private string _filtroTipo = string.Empty;
    private string _filtroEstado = string.Empty;
    private bool mostrarModal = false;
    private int paginaActual = 1;
    private int elementosPorPagina = 10;
    private Cliente clienteEditando = new() 
    { 
        FechaRegistro = DateTime.Now, 
        Activo = true,
        Tipo = TipoCliente.Particular,
        TipoPersona = TipoPersona.Fisica,
        TipoResidencia = TipoResidencia.Residente
    };

    // Sistema modular de pagos (compartido con FacturasVenta)
    private bool mostrarModalListaPagos = false;
    private bool mostrarModalDetallePago = false;
    private Factura? facturaParaPago;
    private Cliente? clienteSeleccionado;
    private List<PagoFactura>? pagosList;
    private PagoFactura? pagoDetalle;

    private string Busqueda
    {
        get => _busqueda;
        set
        {
            if (_busqueda != value)
            {
                _busqueda = value;
                paginaActual = 1;
            }
        }
    }

    private string FiltroTipo
    {
        get => _filtroTipo;
        set
        {
            if (_filtroTipo != value)
            {
                _filtroTipo = value;
                paginaActual = 1;
            }
        }
    }

    private string FiltroEstado
    {
        get => _filtroEstado;
        set
        {
            if (_filtroEstado != value)
            {
                _filtroEstado = value;
                paginaActual = 1;
            }
        }
    }

    private IEnumerable<Cliente> TodosLosFiltrados
    {
        get
        {
            if (clientes == null) return Enumerable.Empty<Cliente>();

            var resultado = clientes.AsEnumerable();

            // Filtro de búsqueda
            if (!string.IsNullOrWhiteSpace(_busqueda))
            {
                resultado = resultado.Where(c =>
                    (c.Nombre?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.Apellidos?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.NombreEmpresa?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.NIF?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.Email?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false)
                );
            }

            // Filtro por tipo
            if (!string.IsNullOrEmpty(_filtroTipo))
            {
                if (Enum.TryParse<TipoCliente>(_filtroTipo, out var tipo))
                {
                    resultado = resultado.Where(c => c.Tipo == tipo);
                }
            }

            // Filtro por estado
            if (!string.IsNullOrEmpty(_filtroEstado))
            {
                if (bool.TryParse(_filtroEstado, out var activo))
                {
                    resultado = resultado.Where(c => c.Activo == activo);
                }
            }

            return resultado;
        }
    }

    private IEnumerable<Cliente> ClientesFiltrados
    {
        get
        {
            return TodosLosFiltrados
                .Skip((paginaActual - 1) * elementosPorPagina)
                .Take(elementosPorPagina);
        }
    }

    private int TotalPaginas => (int)Math.Ceiling((double)TodosLosFiltrados.Count() / elementosPorPagina);

    private void CambiarPagina(int pagina)
    {
        if (pagina >= 1 && pagina <= TotalPaginas)
        {
            paginaActual = pagina;
            StateHasChanged();
        }
    }

    private void ReiniciarPaginacion()
    {
        paginaActual = 1;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
        await CargarProductos();
    }

    private async Task CargarClientes()
    {
        clientes = await ClienteService.ObtenerTodosAsync();
    }

    private async Task CargarProductos()
    {
        productosDisponibles = await ProductoService.ObtenerTodosAsync();
    }

    private void AbrirModalNuevoCliente()
    {
        Console.WriteLine("AbrirModalNuevoCliente llamado");
        clienteEditando = new Cliente 
        { 
            FechaRegistro = DateTime.Now, 
            Activo = true,
            Tipo = TipoCliente.Particular,
            TipoPersona = TipoPersona.Fisica,
            TipoResidencia = TipoResidencia.Residente
        };
        pagosCliente = null; // Limpiar pagos (no hay para clientes nuevos)
        mostrarModal = true;
        Console.WriteLine($"Modal abierto: {mostrarModal}");
        StateHasChanged();
    }

    private async Task AbrirModalEditarCliente(int id)
    {
        Console.WriteLine($"AbrirModalEditarCliente llamado con ID: {id}");
        var cliente = await ClienteService.ObtenerPorIdAsync(id);
        Console.WriteLine($"Cliente obtenido: {cliente?.Nombre ?? "NULL"}");
        Console.WriteLine($"Cliente EmpresaId: {cliente?.EmpresaId.ToString() ?? "NULL"}");
        if (cliente != null)
        {
            clienteEditando = new Cliente
            {
                Id = cliente.Id,
                Tipo = cliente.Tipo,
                NIF = cliente.NIF,
                Nombre = cliente.Nombre,
                Apellidos = cliente.Apellidos,
                NombreEmpresa = cliente.NombreEmpresa,
                Direccion = cliente.Direccion,
                Ciudad = cliente.Ciudad,
                CodigoPostal = cliente.CodigoPostal,
                Provincia = cliente.Provincia,
                Pais = cliente.Pais,
                Telefono = cliente.Telefono,
                Email = cliente.Email,
                EmailSecundario = cliente.EmailSecundario,
                Fax = cliente.Fax,
                ClienteFacturaE = cliente.ClienteFacturaE,
                TipoPersona = cliente.TipoPersona,
                TipoResidencia = cliente.TipoResidencia,
                CodigoINE = cliente.CodigoINE,
                PersonaContacto = cliente.PersonaContacto,
                CuentaBancaria = cliente.CuentaBancaria,
                BIC = cliente.BIC,
                MandateReference = cliente.MandateReference,
                MandateSignatureDate = cliente.MandateSignatureDate,
                FormaPago = cliente.FormaPago,
                LimiteCredito = cliente.LimiteCredito,
                DiasPago = cliente.DiasPago,
                Contacto = cliente.Contacto,
                Activo = cliente.Activo,
                FechaRegistro = cliente.FechaRegistro,
                EmpresaId = cliente.EmpresaId,
                
                // Facturación Masiva
                ProductoRecurrenteId = cliente.ProductoRecurrenteId,
                ConceptoRecurrente = cliente.ConceptoRecurrente,
                ImporteRecurrente = cliente.ImporteRecurrente,
                Periodicidad = cliente.Periodicidad,
                UltimaFacturacion = cliente.UltimaFacturacion,
                FacturacionMasivaActiva = cliente.FacturacionMasivaActiva
            };
            
            // Cargar pagos del cliente
            await CargarPagosCliente(id);
            
            mostrarModal = true;
            Console.WriteLine($"Modal abierto: {mostrarModal}");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "No se pudo cargar el cliente. Puede que no tengas permisos para acceder a este cliente.");
        }
    }

    private async Task GuardarCliente()
    {
        try
        {
            Console.WriteLine($"GuardarCliente - ID: {clienteEditando.Id}, Nombre: {clienteEditando.Nombre}");
            
            if (clienteEditando.Id > 0)
            {
                Console.WriteLine("Actualizando cliente...");
                await ClienteService.ActualizarAsync(clienteEditando.Id, clienteEditando);
            }
            else
            {
                Console.WriteLine("Creando cliente...");
                await ClienteService.CrearAsync(clienteEditando);
            }
            
            Console.WriteLine("Cliente guardado exitosamente");
            CerrarModal();
            await CargarClientes();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar cliente: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", $"Error al guardar el cliente: {ex.Message}");
        }
    }

    private void CerrarModal()
    {
        Console.WriteLine("CerrarModal llamado");
        mostrarModal = false;
        pagosCliente = null; // Limpiar pagos al cerrar
        clienteEditando = new Cliente 
        { 
            FechaRegistro = DateTime.Now, 
            Activo = true,
            Tipo = TipoCliente.Particular,
            TipoPersona = TipoPersona.Fisica,
            TipoResidencia = TipoResidencia.Residente
        };
        Console.WriteLine($"Modal cerrado, mostrarModal: {mostrarModal}");
        StateHasChanged();
    }

    private async Task EliminarCliente(int id)
    {
        var confirmado = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de que desea eliminar este cliente?");
        if (confirmado)
        {
            await ClienteService.EliminarAsync(id);
            await CargarClientes();
            StateHasChanged();
        }
    }

    private async Task CargarPagosCliente(int clienteId)
    {
        try
        {
            var empresaId = await TenantService.GetEmpresaIdAsync();
            if (empresaId.HasValue)
            {
                pagosCliente = await DbContext.PagosFactura
                    .Include(p => p.Factura)
                    .Where(p => p.Factura != null && p.Factura.ClienteId == clienteId && p.Factura.EmpresaId == empresaId.Value)
                    .ToListAsync();
            }
            else
            {
                pagosCliente = new List<PagoFactura>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar pagos del cliente: {ex.Message}");
            pagosCliente = new List<PagoFactura>();
        }
    }

    // Funciones del sistema modular de pagos
    private async Task AbrirPagosCliente(int clienteId)
    {
        try
        {
            var cliente = await ClienteService.ObtenerPorIdAsync(clienteId);
            if (cliente != null)
            {
                clienteSeleccionado = cliente;
                facturaParaPago = null;
                
                // Cargar todos los pagos del cliente
                var todasFacturas = await FacturaService.ObtenerTodosAsync();
                var facturasCliente = todasFacturas.Where(f => f.ClienteId == clienteId && f.TipoFactura == TipoFactura.Venta).ToList();
                
                pagosList = new List<PagoFactura>();
                foreach (var factura in facturasCliente)
                {
                    if (factura.Pagos != null && factura.Pagos.Any())
                    {
                        pagosList.AddRange(factura.Pagos);
                    }
                }
                
                mostrarModalListaPagos = true;
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al cargar pagos: {ex.Message}");
        }
    }

    private async Task AbrirDetallePago(int pagoId)
    {
        try
        {
            pagoDetalle = pagosList?.FirstOrDefault(p => p.Id == pagoId);
            
            if (pagoDetalle == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "No se pudo cargar el detalle del pago");
                return;
            }
            
            mostrarModalDetallePago = true;
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al abrir detalle: {ex.Message}");
        }
    }

    private void CerrarModalDetallePago()
    {
        mostrarModalDetallePago = false;
        pagoDetalle = null;
    }

    private void CerrarModalListaPagos()
    {
        mostrarModalListaPagos = false;
        facturaParaPago = null;
        clienteSeleccionado = null;
        pagosList = null;
    }

    private async Task ExportarPagoXML(int pagoId)
    {
        try
        {
            var empresaId = await TenantService.GetEmpresaIdAsync();
            if (!empresaId.HasValue)
            {
                await JSRuntime.InvokeVoidAsync("alert", "No se pudo obtener la empresa activa");
                return;
            }
            
            var xmlContent = await SEPAService.GenerarXMLSEPA(new List<int> { pagoId }, empresaId.Value);
            var pago = pagosList?.FirstOrDefault(p => p.Id == pagoId) ?? pagoDetalle;
            var fileName = $"Pago_{pago?.Factura?.NumeroFactura ?? "Unknown"}_{pago?.FechaPago:yyyyMMdd}.xml";
            
            await JSRuntime.InvokeVoidAsync("descargarArchivo", fileName, xmlContent, "text/xml");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al exportar pago: {ex.Message}");
        }
    }

    private async Task ExportarSEPA()
    {
        if (pagosList == null || !pagosList.Any())
        {
            await JSRuntime.InvokeVoidAsync("alert", "No hay pagos para exportar");
            return;
        }

        try
        {
            var empresaId = await TenantService.GetEmpresaIdAsync();
            if (!empresaId.HasValue)
            {
                await JSRuntime.InvokeVoidAsync("alert", "No se pudo obtener la empresa activa");
                return;
            }
            
            var pagoIds = pagosList.Select(p => p.Id).ToList();
            
            var xmlContent = await SEPAService.GenerarXMLSEPA(pagoIds, empresaId.Value);
            var fileName = $"SEPA_Cliente_{clienteSeleccionado?.NIF ?? "Unknown"}_{DateTime.Now:yyyyMMdd}.xml";
            
            await JSRuntime.InvokeVoidAsync("descargarArchivo", fileName, xmlContent, "text/xml");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al exportar SEPA: {ex.Message}");
        }
    }

    private string ObtenerClaseEstado(EstadoFactura estado)
    {
        return estado switch
        {
            EstadoFactura.Borrador => "bg-secondary text-white",
            EstadoFactura.Emitida => "text-white",
            EstadoFactura.Enviada => "text-white",
            EstadoFactura.Pagada => "bg-success text-white",
            EstadoFactura.Vencida => "text-dark",
            EstadoFactura.Cancelada => "text-white",
            _ => "bg-secondary text-white"
        };
    }

    private string ObtenerEstiloEstado(EstadoFactura estado)
    {
        return estado switch
        {
            EstadoFactura.Borrador => "background-color: #8ab584;",
            EstadoFactura.Emitida => "background-color: #1e7e34;",
            EstadoFactura.Enviada => "background-color: #5cb85c;",
            EstadoFactura.Pagada => "",
            EstadoFactura.Vencida => "background-color: #a8d5ba;",
            EstadoFactura.Cancelada => "background-color: #155724;",
            _ => "background-color: #8ab584;"
        };
    }

    private async Task ExportarSEPACliente()
    {
        try
        {
            if (pagosCliente == null || !pagosCliente.Any())
            {
                await JSRuntime.InvokeVoidAsync("alert", "No hay pagos para exportar");
                return;
            }

            var empresaId = await TenantService.GetEmpresaIdAsync();
            if (!empresaId.HasValue)
            {
                await JSRuntime.InvokeVoidAsync("alert", "No se pudo obtener la información de la empresa");
                return;
            }

            // Verificar que el cliente tenga IBAN
            if (string.IsNullOrEmpty(clienteEditando.CuentaBancaria))
            {
                await JSRuntime.InvokeVoidAsync("alert", "El cliente no tiene cuenta bancaria (IBAN) configurada");
                return;
            }

            var pagoIds = pagosCliente.Select(p => p.Id).ToList();
            var xml = await SEPAService.GenerarXMLSEPA(pagoIds, empresaId.Value);
            
            var fecha = DateTime.Now.ToString("yyyyMMdd");
            var nombreArchivo = $"SEPA_Cliente_{clienteEditando.NIF}_{fecha}.xml";
            
            await JSRuntime.InvokeVoidAsync("descargarArchivo", nombreArchivo, xml);
            await JSRuntime.InvokeVoidAsync("alert", "Archivo SEPA generado correctamente");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al generar archivo SEPA: {ex.Message}");
            Console.WriteLine($"Error detallado SEPA: {ex}");
        }
    }

    private string ObtenerClaseTipo(TipoCliente tipo)
    {
        return tipo switch
        {
            TipoCliente.Particular => "bg-success",
            TipoCliente.Empresa => "bg-primary",
            TipoCliente.Agencia => "bg-warning",
            _ => "bg-secondary"
        };
    }
}

