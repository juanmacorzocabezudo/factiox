@page "/presupuestos"
@using FactioX.Models
@using FactioX.Services
@inject IPresupuestoService PresupuestoService
@inject IClienteService ClienteService
@inject IProductoService ProductoService
@inject IConfiguracionEmpresaService ConfiguracionEmpresaService
@inject IPresupuestoPdfService PresupuestoPdfService
@inject IEmailService EmailService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Presupuestos - FactioX</PageTitle>

<div class="container-fluid">
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-file-earmark-text"></i> Presupuestos</h2>
        <button class="btn" style="background-color: #5cb85c; color: white;" @onclick="NuevoPresupuesto">
            <i class="bi bi-plus-circle"></i> Nuevo Presupuesto
        </button>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <input type="text" class="form-control" placeholder="Buscar por número o cliente..." @bind="busqueda" @bind:event="oninput" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="filtroEstado">
                        <option value="">Todos los estados</option>
                        <option value="Borrador">Borrador</option>
                        <option value="Enviado">Enviado</option>
                        <option value="Aceptado">Aceptado</option>
                        <option value="Rechazado">Rechazado</option>
                        <option value="Caducado">Caducado</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" class="form-control" @bind="filtroFechaDesde" placeholder="Fecha desde" />
                </div>
                <div class="col-md-3">
                    <input type="date" class="form-control" @bind="filtroFechaHasta" placeholder="Fecha hasta" />
                </div>
            </div>
        </div>
    </div>

    @if (presupuestos == null)
    {
        <p><em>Cargando...</em></p>
    }
    else if (!presupuestos.Any())
    {
        <div class="alert" style="background-color: #d4edda; color: #155724; border-color: #c3e6cb;">
            <i class="bi bi-info-circle"></i> No hay presupuestos registrados.
        </div>
    }
    else
    {
        <!-- Tabla de presupuestos -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Lista de Presupuestos</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Número</th>
                                <th>Cliente</th>
                                <th>Fecha</th>
                                <th>Validez</th>
                                <th class="text-end">Total</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var presupuesto in PresupuestosFiltrados)
                            {
                                <tr @ondblclick="() => EditarPresupuesto(presupuesto.Id)" style="cursor: pointer;">
                                    <td><strong>@presupuesto.Numero</strong></td>
                                    <td>@presupuesto.Cliente?.Nombre</td>
                                    <td>@presupuesto.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>@(presupuesto.FechaValidez?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td class="text-end"><strong>@presupuesto.Total.ToString("C2")</strong></td>
                                    <td>
                                        <span class="badge @ObtenerClaseEstado(presupuesto.Estado)">
                                            @presupuesto.Estado
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm me-1" style="color: #1e7e34; border-color: #1e7e34;" @onclick="() => EditarPresupuesto(presupuesto.Id)" title="Editar">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-sm btn-info me-1" @onclick="() => ImprimirPresupuesto(presupuesto.Id)" title="Imprimir">
                                            <i class="bi bi-printer-fill"></i>
                                        </button>
                                        <button class="btn btn-sm btn-success me-1" @onclick="() => EnviarPorEmailPresupuesto(presupuesto.Id)" title="Enviar por Email">
                                            <i class="bi bi-envelope-fill"></i>
                                        </button>
                                        <button class="btn btn-sm" style="color: #155724; border-color: #155724;" @onclick="() => EliminarPresupuesto(presupuesto.Id)" title="Eliminar">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Estadísticas -->
        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5><i class="bi bi-bar-chart-fill"></i> Estadísticas</h5>
            </div>

            <div class="row">
                <div class="col-md-3">
                    <div class="card" style="background-color: #5cb85c; color: white;">
                        <div class="card-body">
                            <h6>Total Presupuestos</h6>
                            <h3>@presupuestos.Sum(p => p.Total).ToString("C2")</h3>
                            <small>@presupuestos.Count presupuestos</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <h6>Aceptados</h6>
                            <h3>@presupuestos.Where(p => p.Estado == EstadoPresupuesto.Aceptado).Sum(p => p.Total).ToString("C2")</h3>
                            <small>@presupuestos.Count(p => p.Estado == EstadoPresupuesto.Aceptado) presupuestos</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card" style="background-color: #1e7e34; color: white;">
                        <div class="card-body">
                            <h6>Enviados</h6>
                            <h3>@presupuestos.Where(p => p.Estado == EstadoPresupuesto.Enviado).Sum(p => p.Total).ToString("C2")</h3>
                            <small>@presupuestos.Count(p => p.Estado == EstadoPresupuesto.Enviado) presupuestos</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card" style="background-color: #8ab584; color: white;">
                        <div class="card-body">
                            <h6>Borradores</h6>
                            <h3>@presupuestos.Where(p => p.Estado == EstadoPresupuesto.Borrador).Sum(p => p.Total).ToString("C2")</h3>
                            <small>@presupuestos.Count(p => p.Estado == EstadoPresupuesto.Borrador) presupuestos</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal para Nuevo/Editar Presupuesto -->
@if (mostrarModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #5cb85c; color: white;">
                    <h5 class="modal-title">@(presupuestoEditando?.Id > 0 ? "Editar" : "Nuevo") Presupuesto</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    @if (presupuestoEditando != null)
                    {
                        <EditForm Model="@presupuestoEditando" OnValidSubmit="GuardarPresupuesto">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5>Datos del Presupuesto</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label for="cliente" class="form-label">Cliente *</label>
                                                <InputSelect id="cliente" class="form-select" @bind-Value="presupuestoEditando.ClienteId">
                                                    <option value="0">Seleccione un cliente...</option>
                                                    @if (clientes != null)
                                                    {
                                                        @foreach (var cliente in clientes)
                                                        {
                                                            var nombreCliente = cliente.Tipo == TipoCliente.Particular 
                                                                ? $"{cliente.Nombre} {cliente.Apellidos}".Trim()
                                                                : cliente.NombreEmpresa;
                                                            <option value="@cliente.Id">@nombreCliente</option>
                                                        }
                                                    }
                                                </InputSelect>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-4 mb-3">
                                                <label for="fecha" class="form-label">Fecha *</label>
                                                <InputDate id="fecha" class="form-control" @bind-Value="presupuestoEditando.Fecha" />
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <label for="fechaValidez" class="form-label">Fecha Validez</label>
                                                <InputDate id="fechaValidez" class="form-control" @bind-Value="presupuestoEditando.FechaValidez" />
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <label for="estado" class="form-label">Estado</label>
                                                <InputSelect id="estado" class="form-select" @bind-Value="presupuestoEditando.Estado">
                                                    @foreach (EstadoPresupuesto estado in Enum.GetValues(typeof(EstadoPresupuesto)))
                                                    {
                                                        <option value="@estado">@estado</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label for="condicionesPago" class="form-label">Condiciones de Pago</label>
                                                <textarea id="condicionesPago" class="form-control" rows="2" @bind="presupuestoEditando.CondicionesPago" placeholder="Condiciones de pago del presupuesto"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-3">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5>Líneas del Presupuesto</h5>
                                        <button type="button" class="btn btn-sm" style="background-color: #5cb85c; color: white;" @onclick="AgregarLinea">
                                            <i class="bi bi-plus"></i> Agregar Línea
                                        </button>
                                    </div>
                                    <div class="card-body">
                                        @if (presupuestoEditando.Lineas.Any())
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 30%">Producto/Servicio</th>
                                                            <th style="width: 30%">Descripción</th>
                                                            <th style="width: 12%" class="text-end">Cant.</th>
                                                            <th style="width: 13%" class="text-end">Precio</th>
                                                            <th style="width: 15%" class="text-end">Total</th>
                                                            <th style="width: 5%"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @for (int i = 0; i < presupuestoEditando.Lineas.Count; i++)
                                                        {
                                                            var index = i;
                                                            var linea = presupuestoEditando.Lineas[index];
                                                            <tr>
                                                                <td>
                                                                    <InputSelect class="form-select form-select-sm" Value="@linea.ProductoId" ValueChanged="@((int? value) => CambiarProducto(index, value))" ValueExpression="@(() => linea.ProductoId)">
                                                                        <option value="0">Seleccionar...</option>
                                                                        @if (productos != null)
                                                                        {
                                                                            @foreach (var producto in productos)
                                                                            {
                                                                                <option value="@producto.Id">@producto.Nombre</option>
                                                                            }
                                                                        }
                                                                    </InputSelect>
                                                                </td>
                                                                <td>
                                                                    <input type="text" class="form-control form-control-sm" @bind="linea.Descripcion" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.Cantidad" @bind:after="CalcularTotalModal" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.PrecioUnitario" @bind:after="CalcularTotalModal" />
                                                                </td>
                                                                <td class="text-end align-middle">
                                                                    @linea.Subtotal.ToString("C2")
                                                                </td>
                                                                <td>
                                                                    <button type="button" class="btn btn-sm" style="color: #155724; border-color: #155724;" @onclick="() => EliminarLinea(index)">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="text-muted">No hay líneas agregadas</p>
                                        }
                                    </div>
                                </div>

                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5>Observaciones</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label for="notas" class="form-label">Notas / Observaciones</label>
                                            <InputTextArea id="notas" class="form-control" rows="3" @bind-Value="presupuestoEditando.Notas" placeholder="Observaciones adicionales sobre el presupuesto" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="card sticky-top" style="top: 20px;">
                                    <div class="card-header" style="background-color: #5cb85c; color: white;">
                                        <h5>Resumen</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between mb-3">
                                            <strong>Total:</strong>
                                            <strong class="fs-4" style="color: #28a745;">@presupuestoEditando.Total.ToString("C2")</strong>
                                        </div>
                                        <div class="text-muted small text-end fst-italic">
                                            * IVA no incluido
                                        </div>
                                    </div>
                                    <div class="card-footer">
                                        @if (presupuestoEditando.Id > 0)
                                        {
                                            <div class="d-flex gap-2 mb-2">
                                                <button type="button" class="btn btn-success flex-fill" @onclick="() => EnviarPorEmailPresupuesto(presupuestoEditando.Id)" title="Enviar por Email">
                                                    <i class="bi bi-envelope-fill"></i> Enviar Email
                                                </button>
                                                <button type="button" class="btn btn-info flex-fill" @onclick="() => ImprimirPresupuesto(presupuestoEditando.Id)" title="Imprimir">
                                                    <i class="bi bi-printer-fill"></i> Imprimir
                                                </button>
                                            </div>
                                        }
                                        <button type="submit" class="btn w-100 mb-2" style="background-color: #28a745; color: white;">
                                            <i class="bi bi-save"></i> Guardar
                                        </button>
                                        <button type="button" class="btn btn-secondary w-100" @onclick="CerrarModal">
                                            <i class="bi bi-x-circle"></i> Cancelar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<Presupuesto>? presupuestos;
    private List<Cliente>? clientes;
    private List<Producto>? productos;
    private string busqueda = "";
    private string filtroEstado = "";
    private DateTime? filtroFechaDesde;
    private DateTime? filtroFechaHasta;
    private bool mostrarModal = false;
    private Presupuesto presupuestoEditando = new Presupuesto { Lineas = new List<LineaDocumento>() };

    private IEnumerable<Presupuesto> PresupuestosFiltrados
    {
        get
        {
            if (presupuestos == null) return Enumerable.Empty<Presupuesto>();

            var resultado = presupuestos.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(busqueda))
            {
                resultado = resultado.Where(p =>
                    p.Numero.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
                    (p.Cliente?.Nombre?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            if (!string.IsNullOrWhiteSpace(filtroEstado))
            {
                resultado = resultado.Where(p => p.Estado.ToString() == filtroEstado);
            }

            if (filtroFechaDesde.HasValue)
            {
                resultado = resultado.Where(p => p.Fecha >= filtroFechaDesde.Value);
            }

            if (filtroFechaHasta.HasValue)
            {
                resultado = resultado.Where(p => p.Fecha <= filtroFechaHasta.Value);
            }

            return resultado;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarPresupuestos();
        clientes = await ClienteService.ObtenerTodosAsync();
        productos = await ProductoService.ObtenerActivosAsync();
    }

    private async Task CargarPresupuestos()
    {
        presupuestos = await PresupuestoService.ObtenerTodosAsync();
    }

    private void NuevoPresupuesto()
    {
        presupuestoEditando = new Presupuesto
        {
            Fecha = DateTime.Now,
            FechaValidez = DateTime.Now.AddDays(30),
            Estado = EstadoPresupuesto.Borrador,
            Lineas = new List<LineaDocumento>()
        };
        mostrarModal = true;
        CalcularTotalModal();
    }

    private async Task EditarPresupuesto(int id)
    {
        var presupuesto = await PresupuestoService.ObtenerPorIdAsync(id);
        if (presupuesto != null)
        {
            presupuestoEditando = presupuesto;
            mostrarModal = true;
            CalcularTotalModal();
        }
    }

    private async Task EliminarPresupuesto(int id)
    {
        var confirmar = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de que desea eliminar este presupuesto?");
        if (confirmar)
        {
            await PresupuestoService.EliminarAsync(id);
            await CargarPresupuestos();
        }
    }

    private string ObtenerClaseEstado(EstadoPresupuesto estado)
    {
        return estado switch
        {
            EstadoPresupuesto.Borrador => "bg-secondary text-white",
            EstadoPresupuesto.Enviado => "bg-primary text-white",
            EstadoPresupuesto.Aceptado => "bg-success text-white",
            EstadoPresupuesto.Rechazado => "bg-danger text-white",
            EstadoPresupuesto.Caducado => "bg-warning text-dark",
            _ => "bg-secondary text-white"
        };
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        presupuestoEditando = new Presupuesto();
    }

    private async Task GuardarPresupuesto()
    {
        try
        {
            if (presupuestoEditando.ClienteId == 0)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Debe seleccionar un cliente");
                return;
            }

            if (!presupuestoEditando.Lineas.Any())
            {
                await JSRuntime.InvokeVoidAsync("alert", "Debe agregar al menos una línea al presupuesto");
                return;
            }

            if (presupuestoEditando.Id > 0)
            {
                await PresupuestoService.ActualizarAsync(presupuestoEditando.Id, presupuestoEditando);
            }
            else
            {
                await PresupuestoService.CrearAsync(presupuestoEditando);
            }
            
            await CargarPresupuestos();
            CerrarModal();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al guardar el presupuesto: {ex.Message}");
        }
    }

    private void AgregarLinea()
    {
        presupuestoEditando.Lineas.Add(new LineaDocumento
        {
            Cantidad = 1,
            IVA = 0
        });
        CalcularTotalModal();
    }

    private void EliminarLinea(int index)
    {
        presupuestoEditando.Lineas.RemoveAt(index);
        CalcularTotalModal();
    }

    private void CambiarProducto(int index, int? productoId)
    {
        var linea = presupuestoEditando.Lineas[index];
        if (!productoId.HasValue || productoId == 0)
            return;
            
        var producto = productos?.FirstOrDefault(p => p.Id == productoId.Value);
        if (producto != null)
        {
            linea.ProductoId = producto.Id;
            linea.Producto = producto;
            linea.Descripcion = producto.Descripcion ?? producto.Nombre;
            linea.PrecioUnitario = producto.PrecioUnitario;
            linea.IVA = 0; // IVA no incluido en presupuestos
            linea.CalcularImportes();
        }
        
        StateHasChanged();
    }

    private void CalcularTotalModal()
    {
        // Recalcular importes de todas las líneas
        foreach (var linea in presupuestoEditando.Lineas)
        {
            linea.CalcularImportes();
        }
        StateHasChanged();
    }

    private async Task ImprimirPresupuesto(int presupuestoId)
    {
        try
        {
            // Cargar presupuesto completo con cliente y líneas
            var presupuestoCompleto = await PresupuestoService.ObtenerPorIdAsync(presupuestoId);
            
            if (presupuestoCompleto == null || presupuestoCompleto.Cliente == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error al cargar los datos del presupuesto.");
                return;
            }

            var config = await ConfiguracionEmpresaService.ObtenerConfiguracionAsync();

            // Generar el PDF para IMPRIMIR
            byte[] pdfBytes = PresupuestoPdfService.GenerarPresupuestoPdf(presupuestoCompleto, presupuestoCompleto.Cliente, config, paraEmail: true);

            // Convertir a Base64 y usar iframe oculto para imprimir directamente
            string base64Pdf = Convert.ToBase64String(pdfBytes);
            await JSRuntime.InvokeVoidAsync("eval", $@"
                var byteCharacters = atob('{base64Pdf}');
                var byteNumbers = new Array(byteCharacters.length);
                for (var i = 0; i < byteCharacters.length; i++) {{
                    byteNumbers[i] = byteCharacters.charCodeAt(i);
                }}
                var byteArray = new Uint8Array(byteNumbers);
                var blob = new Blob([byteArray], {{type: 'application/pdf'}});
                var url = URL.createObjectURL(blob);
                
                // Crear iframe oculto para imprimir directamente
                var iframe = document.createElement('iframe');
                iframe.style.position = 'fixed';
                iframe.style.right = '0';
                iframe.style.bottom = '0';
                iframe.style.width = '0';
                iframe.style.height = '0';
                iframe.style.border = 'none';
                iframe.src = url;
                document.body.appendChild(iframe);
                
                iframe.onload = function() {{
                    setTimeout(function() {{
                        iframe.contentWindow.focus();
                        iframe.contentWindow.print();
                    }}, 250);
                }};
            ");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al imprimir: {ex.Message}");
        }
    }

    private async Task EnviarPorEmailPresupuesto(int presupuestoId)
    {
        try
        {
            // Cargar presupuesto completo con cliente
            var presupuestoCompleto = await PresupuestoService.ObtenerPorIdAsync(presupuestoId);
            
            if (presupuestoCompleto == null || presupuestoCompleto.Cliente == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error: El presupuesto no tiene un cliente asignado.");
                return;
            }

            // Verificar que el cliente tenga email
            if (string.IsNullOrEmpty(presupuestoCompleto.Cliente.Email))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error: El cliente no tiene un email configurado en su ficha.");
                return;
            }

            var config = await ConfiguracionEmpresaService.ObtenerConfiguracionAsync();

            // Generar PDF para email
            byte[] pdfBytes = PresupuestoPdfService.GenerarPresupuestoPdf(presupuestoCompleto, presupuestoCompleto.Cliente, config, paraEmail: true);

            // Preparar email
            var nombreEmpresa = config?.NombreEmpresa ?? "FactioX";
            var asunto = $"Presupuesto {presupuestoCompleto.Numero} - {nombreEmpresa}";
            
            // Construir cuerpo del email
            var cuerpoBuilder = new System.Text.StringBuilder();
            cuerpoBuilder.AppendLine("<html>");
            cuerpoBuilder.AppendLine("<body style='font-family: Arial, sans-serif;'>");
            cuerpoBuilder.AppendLine($"<h2>Presupuesto {presupuestoCompleto.Numero}</h2>");
            cuerpoBuilder.AppendLine($"<p>Estimado/a {presupuestoCompleto.Cliente.Nombre},</p>");
            cuerpoBuilder.AppendLine($"<p>Adjuntamos el presupuesto <strong>{presupuestoCompleto.Numero}</strong> con fecha {presupuestoCompleto.Fecha:dd/MM/yyyy}.</p>");
            if (presupuestoCompleto.FechaValidez.HasValue)
            {
                cuerpoBuilder.AppendLine($"<p><strong>Válido hasta:</strong> {presupuestoCompleto.FechaValidez.Value:dd/MM/yyyy}</p>");
            }
            cuerpoBuilder.AppendLine($"<p><strong>Importe total:</strong> {presupuestoCompleto.Total:C2}</p>");
            cuerpoBuilder.AppendLine("<p>Para cualquier consulta o para aceptar el presupuesto, no dude en contactarnos.</p>");
            cuerpoBuilder.AppendLine("<br/>");
            cuerpoBuilder.AppendLine($"<p>Atentamente,<br/>{nombreEmpresa}</p>");
            if (!string.IsNullOrEmpty(config?.Email))
            {
                cuerpoBuilder.AppendLine($"<p style='color: #666; font-size: 12px;'>Email: {config.Email}</p>");
            }
            if (!string.IsNullOrEmpty(config?.Telefono))
            {
                cuerpoBuilder.AppendLine($"<p style='color: #666; font-size: 12px;'>Teléfono: {config.Telefono}</p>");
            }
            cuerpoBuilder.AppendLine("</body>");
            cuerpoBuilder.AppendLine("</html>");
            var cuerpo = cuerpoBuilder.ToString();

            var nombreArchivo = $"Presupuesto_{presupuestoCompleto.Numero.Replace("/", "-")}_{DateTime.Now:yyyyMMdd}.pdf";

            // Usar EmailSecundario en CC si existe
            string? cc = !string.IsNullOrEmpty(presupuestoCompleto.Cliente.EmailSecundario) 
                ? presupuestoCompleto.Cliente.EmailSecundario 
                : null;

            // Enviar email
            await EmailService.EnviarEmailConAdjunto(
                presupuestoCompleto.Cliente.Email,
                asunto,
                cuerpo,
                pdfBytes,
                nombreArchivo,
                cc
            );

            await JSRuntime.InvokeVoidAsync("alert", $"Presupuesto enviado correctamente a {presupuestoCompleto.Cliente.Email}");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al enviar email: {ex.Message}\n\nAsegúrate de tener configurado el servidor SMTP en appsettings.json");
        }
    }
}

