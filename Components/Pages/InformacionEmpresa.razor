    private void HandleCertificadoSelected(InputFileChangeEventArgs e)
    {
        errorCertificado = null;
        mensajeArchivo = null;

        try
        {
            certificadoFile = e.File;

            // Validar extensión
            var extension = Path.GetExtension(certificadoFile.Name).ToLower();
            if (extension != ".pfx" && extension != ".p12")
            {
                errorCertificado = "El archivo debe tener extensión .pfx o .p12";
                certificadoFile = null;
                return;
            }

            // Validar tamaño
            if (certificadoFile.Size > maxFileSize)
            {
                errorCertificado = $"El archivo no puede superar {maxFileSize / (1024 * 1024)} MB";
                certificadoFile = null;
                return;
            }

            mensajeArchivo = $"Archivo seleccionado: {certificadoFile.Name} ({certificadoFile.Size / 1024} KB)";
        }
        catch (Exception ex)
        {
            errorCertificado = $"Error al seleccionar el archivo: {ex.Message}";
            certificadoFile = null;
        }
    }

    private async Task GuardarCertificado()
    {
        if (certificadoFile == null || configuracion == null)
        {
            return;
        }

        try
        {
            // Crear directorio para certificados si no existe
            var rutaCertificados = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "certificados");
            if (!Directory.Exists(rutaCertificados))
            {
                Directory.CreateDirectory(rutaCertificados);
            }

            // Generar nombre único para el archivo
            var nombreArchivo = $"cert_{configuracion.EmpresaId}_{DateTime.Now:yyyyMMddHHmmss}{Path.GetExtension(certificadoFile.Name)}";
            var rutaCompleta = Path.Combine(rutaCertificados, nombreArchivo);

            // Eliminar certificado anterior si existe
            if (!string.IsNullOrEmpty(configuracion.CertificadoRuta) && File.Exists(configuracion.CertificadoRuta))
            {
                File.Delete(configuracion.CertificadoRuta);
            }

            // Guardar el archivo
            await using FileStream fs = new(rutaCompleta, FileMode.Create);
            await certificadoFile.OpenReadStream(maxFileSize).CopyToAsync(fs);

            // Actualizar configuración
            configuracion.CertificadoRuta = rutaCompleta;
            
            mensajeArchivo = "Certificado guardado correctamente";
            certificadoFile = null;
        }
        catch (Exception ex)
        {
            errorCertificado = $"Error al guardar el certificado: {ex.Message}";
        }
    }

    private async Task EliminarCertificado()
    {
        if (configuracion == null || string.IsNullOrEmpty(configuracion.CertificadoRuta))
        {
            return;
        }

        try
        {
            var confirmar = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de que desea eliminar el certificado electrónico?");
            if (!confirmar)
            {
                return;
            }

            // Eliminar archivo físico si existe
            if (File.Exists(configuracion.CertificadoRuta))
            {
                File.Delete(configuracion.CertificadoRuta);
            }

            // Limpiar configuración
            configuracion.CertificadoRuta = null;
            configuracion.CertificadoPassword = null;

            await ConfiguracionService.ActualizarAsync(configuracion);
            
            mensajeArchivo = "Certificado eliminado correctamente";
            await JSRuntime.InvokeVoidAsync("alert", "Certificado eliminado correctamente");
        }
        catch (Exception ex)
        {
            errorCertificado = $"Error al eliminar el certificado: {ex.Message}";
            await JSRuntime.InvokeVoidAsync("alert", $"Error al eliminar: {ex.Message}");
        }
    }

    // Funciones para manejo del logo
    private void HandleLogoSelected(InputFileChangeEventArgs e)
    {
        errorLogo = null;
        mensajeArchivoLogo = null;

        try
        {
            logoFile = e.File;

            // Validar extensión
            var extension = Path.GetExtension(logoFile.Name).ToLower();
            if (extension != ".jpg" && extension != ".jpeg" && extension != ".png")
            {
                errorLogo = "El archivo debe ser una imagen .jpg, .jpeg o .png";
                logoFile = null;
                return;
            }

            // Validar tamaño
            if (logoFile.Size > maxLogoSize)
            {
                errorLogo = $"El archivo no puede superar {maxLogoSize / (1024 * 1024)} MB";
                logoFile = null;
                return;
            }

            mensajeArchivoLogo = $"Archivo seleccionado: {logoFile.Name} ({logoFile.Size / 1024} KB)";
        }
        catch (Exception ex)
        {
            errorLogo = $"Error al seleccionar el archivo: {ex.Message}";
            logoFile = null;
        }
    }

    private async Task GuardarLogo()
    {
        if (logoFile == null || configuracion == null)
        {
            return;
        }

        try
        {
            // Crear directorio para logos si no existe
            var rutaLogos = Path.Combine(_webHostEnvironment.WebRootPath, "logos");
            if (!Directory.Exists(rutaLogos))
            {
                Directory.CreateDirectory(rutaLogos);
            }

            // Generar nombre único para el archivo
            var extension = Path.GetExtension(logoFile.Name);
            var nombreArchivo = $"logo_{configuracion.EmpresaId}_{DateTime.Now:yyyyMMddHHmmss}{extension}";
            var rutaCompleta = Path.Combine(rutaLogos, nombreArchivo);

            // Eliminar logo anterior si existe
            if (!string.IsNullOrEmpty(configuracion.LogoRuta))
            {
                var rutaAnterior = Path.Combine(_webHostEnvironment.WebRootPath, configuracion.LogoRuta.TrimStart('/', '\\'));
                if (File.Exists(rutaAnterior))
                {
                    File.Delete(rutaAnterior);
                }
            }

            // Guardar el archivo
            await using FileStream fs = new(rutaCompleta, FileMode.Create);
            await logoFile.OpenReadStream(maxLogoSize).CopyToAsync(fs);

            // Actualizar configuración con ruta relativa
            configuracion.LogoRuta = $"/logos/{nombreArchivo}";
            
            mensajeArchivoLogo = "Logo guardado correctamente";
            logoFile = null;
        }
        catch (Exception ex)
        {
            errorLogo = $"Error al guardar el logo: {ex.Message}";
        }
    }

    private async Task EliminarLogo()
    {
        if (configuracion == null || string.IsNullOrEmpty(configuracion.LogoRuta))
        {
            return;
        }

        try
        {
            var confirmar = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de que desea eliminar el logo?");
            if (!confirmar)
            {
                return;
            }

            // Eliminar archivo físico si existe
            var rutaCompleta = Path.Combine(_webHostEnvironment.WebRootPath, configuracion.LogoRuta.TrimStart('/', '\\'));
            if (File.Exists(rutaCompleta))
            {
                File.Delete(rutaCompleta);
            }

            // Limpiar configuración
            configuracion.LogoRuta = null;

            await ConfiguracionService.ActualizarAsync(configuracion);
            
            mensajeArchivoLogo = "Logo eliminado correctamente";
            await JSRuntime.InvokeVoidAsync("alert", "Logo eliminado correctamente");
        }
        catch (Exception ex)
        {
            errorLogo = $"Error al eliminar el logo: {ex.Message}";
            await JSRuntime.InvokeVoidAsync("alert", $"Error al eliminar: {ex.Message}");
        }
    }
