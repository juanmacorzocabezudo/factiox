@page "/verifactu"
@using FactioX.Services
@inject ITenantService TenantService
@rendermode InteractiveServer

<PageTitle>Verifactu - FactioX</PageTitle>

<div class="container-fluid">
    <div class="mb-4">
        <h2><i class="bi bi-shield-check"></i> Verifactu</h2>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header" style="background-color: #28a745; color: white;">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Módulo en Desarrollo</h5>
                </div>
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-shield-check" style="font-size: 5rem; color: #28a745;"></i>
                    </div>
                    <h3 class="mb-3">Verifactu</h3>
                    <p class="lead mb-4">
                        Sistema de Verificación de Facturas de la Agencia Tributaria
                    </p>
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <strong>Este módulo está actualmente en desarrollo.</strong>
                        <br />
                        Permitirá la integración con el sistema Verifactu de la AEAT para la verificación 
                        y validación automática de facturas electrónicas.
                    </div>
                    <div class="mt-4">
                        <h5 class="mb-3">Funcionalidades planificadas:</h5>
                        <div class="row text-start">
                            <div class="col-md-6">
                                <ul class="list-unstyled">
                                    <li class="mb-2">
                                        <i class="bi bi-check-circle text-success"></i>
                                        Registro automático de facturas
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-check-circle text-success"></i>
                                        Validación en tiempo real
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-check-circle text-success"></i>
                                        Cumplimiento normativo AEAT
                                    </li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <ul class="list-unstyled">
                                    <li class="mb-2">
                                        <i class="bi bi-check-circle text-success"></i>
                                        Gestión de QR de facturas
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-check-circle text-success"></i>
                                        Consulta de estado de facturas
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-check-circle text-success"></i>
                                        Informes de verificación
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4">
                        <a href="/facturas-venta" class="btn btn-primary">
                            <i class="bi bi-arrow-left"></i> Volver a Facturas
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var empresaId = await TenantService.GetEmpresaIdAsync();
        if (!empresaId.HasValue)
        {
            // Redirigir si no hay empresa seleccionada
        }
    }
}
