    private async Task CargarFacturas()
    {
        // Si es Asesoría, cargar facturas de todas las empresas asociadas
        if (AuthService.Rol == Roles.Asesoria)
        {
            var todasLasFacturas = await FacturaService.ObtenerPorEmpresasAsync(AuthService.EmpresaIds);
            facturas = todasLasFacturas.Where(f => f.TipoFactura == TipoFactura.Compra).ToList();
        }
        else
        {
            var todasLasFacturas = await FacturaService.ObtenerTodosAsync();
            facturas = todasLasFacturas.Where(f => f.TipoFactura == TipoFactura.Compra).ToList();
        }
    }
    
    private async Task ExportarAExcel()
