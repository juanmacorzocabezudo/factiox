@page "/facturas-venta"
@using FactioX.Models
@using FactioX.Services
@using System.IO
@inject IFacturaService FacturaService
@inject IClienteService ClienteService
@inject IProductoService ProductoService
@inject ISEPAService SEPAService
@inject IFacturaEService FacturaEService
@inject IFirmaDigitalService FirmaDigitalService
@inject IConfiguracionEmpresaService ConfiguracionEmpresaService
@inject IFacturaPdfService FacturaPdfService
@inject IEmailService EmailService
@inject ITenantService TenantService
@inject IFormaPagoPersonalizadaService FormaPagoService
@inject IAuthService AuthService
@inject IExcelExportService ExcelExportService
@inject IEmpresaService EmpresaService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Facturas de Venta - FactioX</PageTitle>

<div class="container-fluid">
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-receipt"></i> Facturas de Venta</h2>
        <div>
            @if (AuthService.Rol == Roles.Asesoria)
            {
                <button class="btn btn-success" @onclick="ExportarAExcel" disabled="@(facturas == null || !FacturasFiltradas.Any())">
                    <i class="bi bi-file-earmark-excel"></i> Exportar a Excel
                </button>
            }
            else
            {
                <button class="btn" style="background-color: #28a745; color: white;" @onclick="NuevaFactura">
                    <i class="bi bi-plus-circle"></i> Nueva Factura de Venta
                </button>
            }
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <input type="text" class="form-control" placeholder="Buscar por número o cliente..." @bind="busqueda" @bind:event="oninput" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="filtroEstado">
                        <option value="">Todos los estados</option>
                        <option value="Borrador">Borrador</option>
                        <option value="Emitida">Emitida</option>
                        <option value="Enviada">Enviada</option>
                        <option value="Pagada">Pagada</option>
                        <option value="Vencida">Vencida</option>
                        <option value="Cancelada">Cancelada</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" class="form-control" @bind="filtroFechaDesde" placeholder="Fecha desde" />
                </div>
                <div class="col-md-3">
                    <input type="date" class="form-control" @bind="filtroFechaHasta" placeholder="Fecha hasta" />
                </div>
            </div>
            @if (AuthService.Rol == Roles.Asesoria)
            {
                <div class="row mt-3">
                    <div class="col-md-12">
                        <label class="form-label"><strong>Filtrar por empresas:</strong></label>
                        <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto; background-color: #f8f9fa;">
                            @if (empresasAsociadas != null && empresasAsociadas.Any())
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" 
                                           checked="@(filtroEmpresaIds.Count == 0)" 
                                           @onchange="@((ChangeEventArgs e) => ToggleTodasEmpresas((bool)e.Value!))" />
                                    <label class="form-check-label fw-bold">
                                        Todas las empresas
                                    </label>
                                </div>
                                <hr class="my-2" />
                                @foreach (var empresa in empresasAsociadas.OrderBy(e => e.NombreComercial))
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" 
                                               checked="@filtroEmpresaIds.Contains(empresa.Id)" 
                                               @onchange="@((ChangeEventArgs e) => ToggleFiltroEmpresa(empresa.Id, (bool)e.Value!))" />
                                        <label class="form-check-label">
                                            @empresa.NombreComercial
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted mb-0">No hay empresas asociadas</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (facturas == null)
    {
        <p><em>Cargando...</em></p>
    }
    else if (!facturas.Any())
    {
        <div class="alert" style="background-color: #d4edda; color: #155724; border-color: #c3e6cb;">
            <i class="bi bi-info-circle"></i> No hay facturas de venta registradas.
        </div>
    }
    else
    {
        <!-- Tabla de facturas -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Lista de Facturas</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Número</th>
                                @if (AuthService.Rol == Roles.Asesoria)
                                {
                                    <th>Empresa</th>
                                }
                                <th>Cliente</th>
                                <th>Fecha Emisión</th>
                                <th>Vencimiento</th>
                                <th class="text-end">Base</th>
                                <th class="text-end">IVA</th>
                                <th class="text-end">Total</th>
                                @if (AuthService.Rol != Roles.Asesoria)
                                {
                                    <th class="text-end">Pagado</th>
                                    <th class="text-end">Pendiente</th>
                                    <th>Estado</th>
                                }
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var factura in FacturasFiltradas)
                            {
                                <tr class="@(factura.Estado == EstadoFactura.Vencida ? "table-warning" : "")" 
                                    @ondblclick="@(() => AbrirFactura(factura.Id))" 
                                    style="cursor: pointer;">
                                    <td><strong>@factura.NumeroFactura</strong></td>
                                    @if (AuthService.Rol == Roles.Asesoria)
                                    {
                                        <td><span class="badge bg-secondary">@factura.Empresa?.NombreComercial</span></td>
                                    }
                                    <td>
                                        @if (factura.Cliente != null)
                                        {
                                            if (factura.Cliente.Tipo == TipoCliente.Empresa)
                                            {
                                                @factura.Cliente.NombreEmpresa
                                            }
                                            else
                                            {
                                                @($"{factura.Cliente.Nombre} {factura.Cliente.Apellidos}".Trim())
                                            }
                                        }
                                    </td>
                                    <td>@factura.FechaEmision.ToString("dd/MM/yyyy")</td>
                                    <td>@(factura.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td class="text-end">@factura.BaseImponible.ToString("C2")</td>
                                    <td class="text-end">@factura.ImporteIVA.ToString("C2")</td>
                                    <td class="text-end"><strong>@factura.Total.ToString("C2")</strong></td>
                                    @if (AuthService.Rol != Roles.Asesoria)
                                    {
                                        <td class="text-end">
                                            @if (factura.TotalPagado > 0)
                                            {
                                                <span class="text-success"><strong>@factura.TotalPagado.ToString("C2")</strong></span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">@factura.TotalPagado.ToString("C2")</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (factura.PendientePago > 0)
                                            {
                                                <span class="@(factura.PendientePago == factura.Total ? "text-danger" : "text-warning")">
                                                    <strong>@factura.PendientePago.ToString("C2")</strong>
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">@factura.PendientePago.ToString("C2")</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @ObtenerClaseEstado(factura.Estado)" style="@ObtenerEstiloEstado(factura.Estado)">
                                                @factura.Estado
                                            </span>
                                            @if (factura.TienePagosParciales)
                                            {
                                                <br /><span class="badge mt-1" style="background-color: #5cb85c; color: white;">Pago Parcial</span>
                                            }
                                        </td>
                                    }
                                    <td>
                                        @if (AuthService.Rol != Roles.Asesoria)
                                        {
                                            @if (factura.PendientePago > 0)
                                            {
                                                <button class="btn btn-sm btn-outline-success me-1" @onclick="() => GestionarPagos(factura.Id)" title="Gestionar Pagos">
                                                    <i class="bi bi-cash-coin"></i>
                                                </button>
                                            }
                                            @if (!string.IsNullOrEmpty(factura.DocumentoAdjunto))
                                            {
                                                <button class="btn btn-sm btn-outline-success me-1" @onclick="() => DescargarDocumentoListado(factura)" title="Descargar Documento">
                                                    <i class="bi bi-file-earmark-arrow-down-fill"></i>
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-outline-success me-1" @onclick="() => EnviarPorEmail(factura)" title="Enviar por Email">
                                                <i class="bi bi-envelope-fill"></i>
                                            </button>
                                            <button class="btn btn-sm me-1" style="color: #5cb85c; border-color: #5cb85c;" @onclick="() => Imprimir(factura)" title="Imprimir">
                                                <i class="bi bi-printer-fill"></i>
                                            </button>
                                            <button class="btn btn-sm me-1" style="color: #28a745; border-color: #28a745;" @onclick="() => ExportarFacturaE(factura)" title="Exportar FacturaE XML">
                                                <i class="bi bi-file-earmark-code"></i>
                                            </button>
                                            <button class="btn btn-sm me-1" style="color: #1e7e34; border-color: #1e7e34;" @onclick="() => EditarFactura(factura.Id)" title="Editar">
                                                <i class="bi bi-pencil-fill"></i>
                                            </button>
                                            <button class="btn btn-sm" style="color: #155724; border-color: #155724;" @onclick="() => EliminarFactura(factura.Id)" title="Eliminar">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            @* Acciones para Asesoría *@
                                            <button class="btn btn-sm me-1" style="color: #28a745; border-color: #28a745;" @onclick="@(() => AbrirFactura(factura.Id))" title="Ver Factura">
                                                <i class="bi bi-eye-fill"></i>
                                            </button>
                                            <button class="btn btn-sm me-1" style="color: #5cb85c; border-color: #5cb85c;" @onclick="() => Imprimir(factura)" title="Imprimir">
                                                <i class="bi bi-printer-fill"></i>
                                            </button>
                                            @if (!string.IsNullOrEmpty(factura.DocumentoAdjunto))
                                            {
                                                <button class="btn btn-sm btn-outline-success" @onclick="() => DescargarDocumentoListado(factura)" title="Descargar Documento">
                                                    <i class="bi bi-file-earmark-arrow-down-fill"></i>
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Estadísticas -->
        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5><i class="bi bi-bar-chart-fill"></i> Estadísticas</h5>
            </div>

            <div class="row">
                <div class="col-md-3">
                    <div class="card" style="background-color: #1e7e34; color: white;">
                        <div class="card-body">
                            <h6>Total Facturado</h6>
                            <h3>@facturas.Sum(f => f.Total).ToString("C2")</h3>
                            <small>@facturas.Count facturas</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <h6>Cobradas</h6>
                            <h3>@facturas.Where(f => f.Estado == EstadoFactura.Pagada).Sum(f => f.Total).ToString("C2")</h3>
                            <small>@facturas.Count(f => f.Estado == EstadoFactura.Pagada) facturas</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card" style="background-color: #a8d5ba; color: #155724;">
                        <div class="card-body">
                            <h6>Pendientes</h6>
                            <h3>@facturas.Where(f => f.Estado == EstadoFactura.Emitida || f.Estado == EstadoFactura.Enviada).Sum(f => f.Total).ToString("C2")</h3>
                            <small>@facturas.Count(f => f.Estado == EstadoFactura.Emitida || f.Estado == EstadoFactura.Enviada) facturas</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card" style="background-color: #155724; color: white;">
                        <div class="card-body">
                            <h6>Vencidas</h6>
                            <h3>@facturas.Where(f => f.Estado == EstadoFactura.Vencida).Sum(f => f.Total).ToString("C2")</h3>
                            <small>@facturas.Count(f => f.Estado == EstadoFactura.Vencida) facturas</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Gráficos -->
            <div class="row mt-4">
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="bi bi-bar-chart"></i> Facturas por Estado</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="chartFacturasPorEstado" style="max-height: 300px;"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="bi bi-pie-chart"></i> Distribución de Importes</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="chartDistribucionImportes" style="max-height: 300px;"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal para Nueva/Editar Factura -->
@if (mostrarModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #28a745; color: white;">
                    <h5 class="modal-title">
                        @if (AuthService.Rol == Roles.Asesoria)
                        {
                            <text>Ver Factura de Venta</text>
                        }
                        else
                        {
                            <text>@(facturaEditando?.Id > 0 ? "Editar" : "Nueva") Factura de Venta</text>
                        }
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@facturaEditando" OnValidSubmit="GuardarFactura">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5>Datos de la Factura</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label for="cliente" class="form-label">Cliente *</label>
                                                <div class="input-group">
                                                    <select id="cliente" class="form-select" value="@facturaEditando.ClienteId" @onchange="@((ChangeEventArgs e) => OnClienteChangedAsync(int.Parse(e.Value?.ToString() ?? "0")))" disabled="@(AuthService.Rol == Roles.Asesoria)">
                                                        <option value="0">Seleccione un cliente...</option>
                                                        @if (clientes != null && clientes.Any())
                                                        {
                                                            @foreach (var cliente in clientes)
                                                            {
                                                                var nombreCliente = cliente.Tipo == TipoCliente.Particular 
                                                                    ? $"{cliente.Nombre} {cliente.Apellidos}".Trim()
                                                                    : cliente.NombreEmpresa;
                                                                <option value="@cliente.Id">@nombreCliente</option>
                                                            }
                                                        }
                                                    </select>
                                                    @if (AuthService.Rol != Roles.Asesoria)
                                                    {
                                                        @if (facturaEditando.ClienteId > 0)
                                                        {
                                                            <button type="button" class="btn btn-outline-primary" @onclick="VerCliente" title="Ver/Editar cliente">
                                                                <i class="bi bi-person-vcard"></i>
                                                            </button>
                                                        }
                                                        <button type="button" class="btn btn-outline-success" @onclick="CrearCliente" title="Crear nuevo cliente">
                                                            <i class="bi bi-person-plus"></i>
                                                        </button>
                                                    }
                                                </div>
                                                @if (clientes == null || !clientes.Any())
                                                {
                                                    <small style="color: #7cb342;">
                                                        <i class="bi bi-exclamation-triangle"></i> No hay clientes disponibles. <a href="/clientes" style="color: #1e7e34;">Crear cliente</a>
                                                    </small>
                                                }
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-3 mb-3">
                                                <label for="fecha" class="form-label">Fecha Emisión *</label>
                                                <InputDate id="fecha" class="form-control" @bind-Value="facturaEditando.FechaEmision" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="fechaVencimiento" class="form-label">Fecha Vencimiento</label>
                                                <InputDate id="fechaVencimiento" class="form-control" @bind-Value="facturaEditando.FechaVencimiento" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="fechaOperacion" class="form-label">Fecha Operación</label>
                                                <InputDate id="fechaOperacion" class="form-control" @bind-Value="facturaEditando.FechaOperacion" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                <small class="text-muted">Fecha real del servicio</small>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="estado" class="form-label">Estado</label>
                                                <InputSelect id="estado" class="form-select" @bind-Value="facturaEditando.Estado" disabled="@(AuthService.Rol == Roles.Asesoria)">
                                                    @foreach (EstadoFactura estado in Enum.GetValues(typeof(EstadoFactura)))
                                                    {
                                                        <option value="@estado">@estado</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-3 mb-3">
                                                <label for="formaPago" class="form-label">Forma de Pago</label>
                                                <InputSelect id="formaPago" class="form-control" @bind-Value="facturaEditando.FormaPago" disabled="@(AuthService.Rol == Roles.Asesoria)">
                                                    <option value="">Seleccione...</option>
                                                    @foreach (var forma in Enum.GetValues<FormaPago>())
                                                    {
                                                        <option value="@forma">@ObtenerNombreFormaPago(forma)</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="periodoInicio" class="form-label">Período Inicio</label>
                                                <InputDate id="periodoInicio" class="form-control" @bind-Value="facturaEditando.FechaPeriodoInicio" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                <small class="text-muted">Para servicios periódicos</small>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="periodoFin" class="form-label">Período Fin</label>
                                                <InputDate id="periodoFin" class="form-control" @bind-Value="facturaEditando.FechaPeriodoFin" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                <small class="text-muted">Para servicios periódicos</small>
                                            </div>
                                            @if (facturaEditando.Estado == EstadoFactura.Pagada)
                                            {
                                                <div class="col-md-3 mb-3">
                                                    <label for="fechaPago" class="form-label">Fecha de Pago</label>
                                                    <InputDate id="fechaPago" class="form-control" @bind-Value="facturaEditando.FechaPago" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                </div>
                                            }
                                        </div>
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label for="concepto" class="form-label">Concepto</label>
                                                <textarea id="concepto" class="form-control" rows="2" @bind="facturaEditando.Concepto" placeholder="Descripción del servicio facturado" disabled="@(AuthService.Rol == Roles.Asesoria)"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-3">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5>Líneas de la Factura</h5>
                                        @if (AuthService.Rol != Roles.Asesoria)
                                        {
                                            <button type="button" class="btn btn-sm" style="background-color: #28a745; color: white;" @onclick="AgregarLinea">
                                                <i class="bi bi-plus"></i> Agregar Línea
                                            </button>
                                        }
                                    </div>
                                    <div class="card-body">
                                        @if (facturaEditando.Lineas.Any())
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 30%">Producto/Servicio</th>
                                                            <th style="width: 20%">Descripción</th>
                                                            <th style="width: 10%" class="text-end">Cant.</th>
                                                            <th style="width: 12%" class="text-end">Precio</th>
                                                            <th style="width: 10%" class="text-end">Desc. %</th>
                                                            <th style="width: 10%" class="text-end">IVA %</th>
                                                            <th style="width: 13%" class="text-end">Total</th>
                                                            <th style="width: 5%"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @for (int i = 0; i < facturaEditando.Lineas.Count; i++)
                                                        {
                                                            var index = i;
                                                            var linea = facturaEditando.Lineas[index];
                                                            <tr>
                                                                <td>
                                                                    <InputSelect class="form-select form-select-sm" Value="@linea.ProductoId" ValueChanged="@((int? value) => CambiarProducto(index, value))" ValueExpression="@(() => linea.ProductoId)" disabled="@(AuthService.Rol == Roles.Asesoria)">
                                                                        <option value="0">Seleccionar...</option>
                                                                        @if (productos != null)
                                                                        {
                                                                            @foreach (var producto in productos)
                                                                            {
                                                                                <option value="@producto.Id">@producto.Nombre</option>
                                                                            }
                                                                        }
                                                                    </InputSelect>
                                                                </td>
                                                                <td>
                                                                    <input type="text" class="form-control form-control-sm" @bind="linea.Descripcion" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.Cantidad" @bind:after="CalcularTotalModal" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.PrecioUnitario" @bind:after="CalcularTotalModal" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.Descuento" @bind:after="CalcularTotalModal" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.IVA" @bind:after="CalcularTotalModal" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                                </td>
                                                                <td class="text-end align-middle">
                                                                    @linea.Total.ToString("C2")
                                                                </td>
                                                                <td>
                                                                    @if (AuthService.Rol != Roles.Asesoria)
                                                                    {
                                                                        <button type="button" class="btn btn-sm" style="color: #155724; border-color: #155724;" @onclick="() => EliminarLinea(index)">
                                                                            <i class="bi bi-trash"></i>
                                                                        </button>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                            @if (productos == null || !productos.Any())
                                            {
                                                <div class="alert mt-2 mb-0" style="background-color: #d4edda; color: #155724; border-color: #c3e6cb;">
                                                    <i class="bi bi-exclamation-triangle"></i> No hay productos disponibles. <a href="/productos" style="color: #1e7e34;">Crear producto</a>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <p class="text-muted">No hay líneas agregadas</p>
                                        }
                                    </div>
                                </div>

                                <!-- Cálculos e Importes -->
                                <div class="card mb-3">
                                    <div class="card-header" style="background-color: #1e7e34; color: white;">
                                        <h5 class="mb-0"><i class="bi bi-calculator"></i> Cálculos e Importes</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Descuentos Generales (€)</label>
                                                <input type="number" step="0.01" class="form-control" @bind="facturaEditando.DescuentosGenerales" @bind:after="CalcularTotalModal" placeholder="0.00" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                <small class="text-muted">Descuentos sobre el total de la factura</small>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Recargos Generales (€)</label>
                                                <input type="number" step="0.01" class="form-control" @bind="facturaEditando.RecargosGenerales" @bind:after="CalcularTotalModal" placeholder="0.00" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                <small class="text-muted">Recargos adicionales (ej: recargo de equivalencia)</small>
                                            </div>
                                        </div>
                                        
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Cargos Adicionales (€)</label>
                                                <input type="number" step="0.01" class="form-control" @bind="facturaEditando.CargosAdicionales" @bind:after="CalcularTotalModal" placeholder="0.00" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                <small class="text-muted">Gastos de envío, gestión, etc.</small>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Concepto de Cargos</label>
                                                <input type="text" class="form-control" @bind="facturaEditando.ConceptoCargos" placeholder="Ej: Gastos de gestión" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                            </div>
                                        </div>
                                        
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Retención IRPF (%)</label>
                                                <input type="number" step="0.01" class="form-control" @bind="facturaEditando.PorcentajeRetencion" @bind:after="CalcularTotalModal" placeholder="0.00" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                                <small class="text-muted">Retención aplicable (opcional)</small>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Importe Retención (€)</label>
                                                <input type="number" step="0.01" class="form-control" value="@facturaEditando.ImporteRetencion.ToString("F2")" readonly style="background-color: #f8f9fa;" />
                                            </div>
                                        </div>

                                        <div class="alert mt-3" style="background-color: #d4edda; color: #155724; border-color: #c3e6cb;" role="alert">
                                            <small>
                                                <strong>Cálculo:</strong> Subtotal - Descuentos + Recargos + IVA + Cargos - Retención = <strong>@facturaEditando.Total.ToString("C2")</strong>
                                            </small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Datos para FacturaE -->
                                <div class="card mb-3">
                                    <div class="card-header" style="background-color: #5cb85c; color: white;">
                                        <h5 class="mb-0"><i class="bi bi-file-earmark-text"></i> Datos para FacturaE</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">Clase de Factura</label>
                                                <InputSelect class="form-select" @bind-Value="facturaEditando.ClaseFactura" disabled="@(AuthService.Rol == Roles.Asesoria)">
                                                    @foreach (var clase in Enum.GetValues<ClaseFactura>())
                                                    {
                                                        <option value="@clase">@clase</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">Tipo de Factura</label>
                                                <InputSelect class="form-select" @bind-Value="facturaEditando.TipoFactura" disabled="@(AuthService.Rol == Roles.Asesoria)">
                                                    @foreach (var tipo in Enum.GetValues<TipoFactura>())
                                                    {
                                                        <option value="@tipo">@tipo</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">Lugar de Expedición</label>
                                                <input type="text" class="form-control" @bind="facturaEditando.LugarExpedicion" placeholder="Ciudad" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">CP Expedición</label>
                                                <input type="text" class="form-control" @bind="facturaEditando.CodigoPostalExpedicion" placeholder="28001" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5>Observaciones</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label for="notas" class="form-label">Notas / Observaciones</label>
                                            <InputTextArea id="notas" class="form-control" rows="3" @bind-Value="facturaEditando.Observaciones" placeholder="Observaciones adicionales sobre la factura" disabled="@(AuthService.Rol == Roles.Asesoria)" />
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-3">
                                    <div class="card-header" style="background-color: #28a745; color: white;">
                                        <h5 class="mb-0"><i class="bi bi-paperclip"></i> Documento Adjunto</h5>
                                    </div>
                                    <div class="card-body">
                                        @if (!string.IsNullOrEmpty(facturaEditando.DocumentoAdjunto))
                                        {
                                            <div class="alert alert-success mb-3" role="alert">
                                                <i class="bi bi-file-earmark-check-fill"></i> 
                                                <strong>Documento adjunto:</strong> @facturaEditando.NombreDocumento
                                                <div class="mt-2">
                                                    <button type="button" class="btn btn-sm btn-success me-2" @onclick="DescargarDocumento">
                                                        <i class="bi bi-download"></i> Descargar
                                                    </button>
                                                    @if (AuthService.Rol != Roles.Asesoria)
                                                    {
                                                        <button type="button" class="btn btn-sm btn-danger" @onclick="EliminarDocumento">
                                                            <i class="bi bi-trash"></i> Eliminar
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        @if (AuthService.Rol != Roles.Asesoria)
                                        {
                                            <div class="mb-3">
                                                <label class="form-label">Adjuntar Documento (PDF, imágenes, etc.)</label>
                                                <InputFile class="form-control" OnChange="CargarDocumento" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />
                                                <small class="text-muted">Tamaño máximo: 30MB. El archivo se comprimirá automáticamente si es posible.</small>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="card sticky-top" style="top: 20px;">
                                    <div class="card-header bg-success text-white">
                                        <h5>Resumen</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Subtotal Líneas:</span>
                                            <strong>@facturaEditando.Subtotal.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Descuentos:</span>
                                            <strong class="text-danger">-@facturaEditando.DescuentosGenerales.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Recargos:</span>
                                            <strong class="text-success">+@facturaEditando.RecargosGenerales.ToString("C2")</strong>
                                        </div>
                                        <hr />
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Base Imponible:</span>
                                            <strong>@facturaEditando.BaseImponible.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>IVA:</span>
                                            <strong>@facturaEditando.TotalIVA.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Cargos Adicionales:</span>
                                            <strong>@facturaEditando.CargosAdicionales.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Retención IRPF:</span>
                                            <strong class="text-danger">-@facturaEditando.ImporteRetencion.ToString("C2")</strong>
                                        </div>
                                        <hr />
                                        <div class="d-flex justify-content-between">
                                            <strong>Total:</strong>
                                            <strong class="fs-4 text-success">@facturaEditando.Total.ToString("C2")</strong>
                                        </div>
                                        @if (facturaEditando.Id > 0 && AuthService.Rol != Roles.Asesoria)
                                        {
                                            <hr />
                                            <div class="d-flex justify-content-between mb-2">
                                                <span>Pagado:</span>
                                                <strong class="text-success">@facturaEditando.TotalPagado.ToString("C2")</strong>
                                            </div>
                                            <div class="d-flex justify-content-between">
                                                <span>Pendiente:</span>
                                                <strong class="@(facturaEditando.PendientePago > 0 ? "text-danger" : "text-success")">@facturaEditando.PendientePago.ToString("C2")</strong>
                                            </div>
                                        }
                                    </div>
                                    <div class="card-footer">
                                        @if (AuthService.Rol != Roles.Asesoria)
                                        {
                                            <button type="submit" class="btn btn-success w-100 mb-2">
                                                <i class="bi bi-save"></i> Guardar
                                            </button>
                                            @if (facturaEditando.Id > 0 && facturaEditando.PendientePago > 0)
                                            {
                                                <button type="button" class="btn w-100 mb-2" style="background-color: #28a745; color: white;" @onclick="() => GestionarPagos(facturaEditando.Id)">
                                                    <i class="bi bi-cash-coin"></i> Gestionar Pagos (@facturaEditando.PendientePago.ToString("C2") pendiente)
                                                </button>
                                            }
                                        }
                                        
                                        @if (facturaEditando.Id > 0)
                                        {
                                            <hr class="my-2" />
                                            <div class="d-grid gap-2">
                                                <button type="button" class="btn" style="color: #1e7e34; border-color: #1e7e34;" @onclick="ImprimirFactura">
                                                    <i class="bi bi-printer"></i> Imprimir
                                                </button>
                                                @if (AuthService.Rol != Roles.Asesoria)
                                                {
                                                    <button type="button" class="btn" style="color: #5cb85c; border-color: #5cb85c;" @onclick="EnviarEmail">
                                                        <i class="bi bi-envelope"></i> Enviar Email
                                                    </button>
                                                    <div class="btn-group w-100" role="group">
                                                        <button type="button" class="btn btn-outline-success" @onclick="ExportarXML">
                                                            <i class="bi bi-file-earmark-code"></i> Exportar XML
                                                        </button>
                                                        <button type="button" class="btn btn-outline-success" @onclick="ExportarXMLFirmado">
                                                            <i class="bi bi-file-earmark-lock"></i> XML Firmado
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                            <hr class="my-2" />
                                        }
                                        
                                        <button type="button" class="btn btn-secondary w-100" @onclick="CerrarModal">
                                            <i class="bi bi-x-circle"></i> @(AuthService.Rol == Roles.Asesoria ? "Cerrar" : "Cancelar")
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<!-- Modal de Visualización Solo Lectura para Asesoría -->
@if (mostrarModalVer)
{
    <div class="modal fade show" style="display: block; z-index: 1056;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #28a745; color: white;">
                    <h5 class="modal-title">
                        <i class="bi bi-eye"></i> Ver Factura de Venta @(facturaVisualizacion != null ? $"- {facturaVisualizacion.NumeroFactura}" : "")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalVer"></button>
                </div>
                <div class="modal-body">
                    @if (facturaVisualizacion != null)
                    {
                        <div class="row">
                            <div class="col-md-8">
                            <!-- Datos del Cliente -->
                            <div class="card mb-3">
                                <div class="card-header" style="background-color: #28a745; color: white;">
                                    <h5 class="mb-0"><i class="bi bi-person-badge"></i> Cliente</h5>
                                </div>
                                <div class="card-body">
                                    @if (facturaVisualizacion.Cliente != null)
                                    {
                                        <div class="row">
                                            <div class="col-md-6 mb-2">
                                                <strong>Nombre:</strong><br/>
                                                @if (facturaVisualizacion.Cliente.Tipo == TipoCliente.Particular)
                                                {
                                                    <span>@facturaVisualizacion.Cliente.Nombre @facturaVisualizacion.Cliente.Apellidos</span>
                                                }
                                                else
                                                {
                                                    <span>@facturaVisualizacion.Cliente.NombreEmpresa</span>
                                                }
                                            </div>
                                            <div class="col-md-6 mb-2">
                                                <strong>NIF:</strong><br/>
                                                <span>@facturaVisualizacion.Cliente.NIF</span>
                                            </div>
                                            <div class="col-md-6 mb-2">
                                                <strong>Email:</strong><br/>
                                                <span>@facturaVisualizacion.Cliente.Email</span>
                                            </div>
                                            <div class="col-md-6 mb-2">
                                                <strong>Teléfono:</strong><br/>
                                                <span>@facturaVisualizacion.Cliente.Telefono</span>
                                            </div>
                                            <div class="col-md-12 mb-2">
                                                <strong>Dirección:</strong><br/>
                                                <span>@facturaVisualizacion.Cliente.Direccion</span><br/>
                                                <span>@facturaVisualizacion.Cliente.CodigoPostal @facturaVisualizacion.Cliente.Ciudad</span><br/>
                                                <span>@facturaVisualizacion.Cliente.Provincia, @facturaVisualizacion.Cliente.Pais</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Datos de la Factura -->
                            <div class="card mb-3">
                                <div class="card-header" style="background-color: #5cb85c; color: white;">
                                    <h5 class="mb-0"><i class="bi bi-file-text"></i> Datos de la Factura</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-3 mb-2">
                                            <strong>Número:</strong><br/>
                                            <span>@facturaVisualizacion.NumeroFactura</span>
                                        </div>
                                        <div class="col-md-3 mb-2">
                                            <strong>Fecha Emisión:</strong><br/>
                                            <span>@facturaVisualizacion.FechaEmision.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="col-md-3 mb-2">
                                            <strong>Fecha Vencimiento:</strong><br/>
                                            <span>@(facturaVisualizacion.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "-")</span>
                                        </div>
                                        <div class="col-md-3 mb-2">
                                            <strong>Estado:</strong><br/>
                                            <span class="badge @ObtenerClaseEstado(facturaVisualizacion.Estado)">@facturaVisualizacion.Estado</span>
                                        </div>
                                        @if (facturaVisualizacion.FechaOperacion.HasValue)
                                        {
                                            <div class="col-md-3 mb-2">
                                                <strong>Fecha Operación:</strong><br/>
                                                <span>@facturaVisualizacion.FechaOperacion?.ToString("dd/MM/yyyy")</span>
                                            </div>
                                        }
                                        @if (facturaVisualizacion.FormaPago.HasValue)
                                        {
                                            <div class="col-md-3 mb-2">
                                                <strong>Forma de Pago:</strong><br/>
                                                <span>@ObtenerNombreFormaPago(facturaVisualizacion.FormaPago.Value)</span>
                                            </div>
                                        }
                                        @if (facturaVisualizacion.FechaPeriodoInicio.HasValue || facturaVisualizacion.FechaPeriodoFin.HasValue)
                                        {
                                            <div class="col-md-6 mb-2">
                                                <strong>Período:</strong><br/>
                                                <span>@(facturaVisualizacion.FechaPeriodoInicio?.ToString("dd/MM/yyyy") ?? "-") - @(facturaVisualizacion.FechaPeriodoFin?.ToString("dd/MM/yyyy") ?? "-")</span>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(facturaVisualizacion.Concepto))
                                        {
                                            <div class="col-md-12 mb-2">
                                                <strong>Concepto:</strong><br/>
                                                <span>@facturaVisualizacion.Concepto</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Líneas de la Factura -->
                            @if (facturaVisualizacion.Lineas != null && facturaVisualizacion.Lineas.Any())
                            {
                                <div class="card mb-3">
                                    <div class="card-header" style="background-color: #1e7e34; color: white;">
                                        <h5 class="mb-0"><i class="bi bi-list-ul"></i> Líneas de la Factura</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-sm">
                                                <thead>
                                                    <tr>
                                                        <th>Descripción</th>
                                                        <th class="text-end">Cantidad</th>
                                                        <th class="text-end">Precio</th>
                                                        <th class="text-end">Desc. %</th>
                                                        <th class="text-end">IVA %</th>
                                                        <th class="text-end">Total</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var linea in facturaVisualizacion.Lineas)
                                                    {
                                                        <tr>
                                                            <td>@linea.Descripcion</td>
                                                            <td class="text-end">@linea.Cantidad</td>
                                                            <td class="text-end">@linea.PrecioUnitario.ToString("C2")</td>
                                                            <td class="text-end">@linea.Descuento%</td>
                                                            <td class="text-end">@linea.IVA%</td>
                                                            <td class="text-end"><strong>@linea.Total.ToString("C2")</strong></td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Observaciones -->
                            @if (!string.IsNullOrEmpty(facturaVisualizacion.Observaciones))
                            {
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5 class="mb-0"><i class="bi bi-chat-square-text"></i> Observaciones</h5>
                                    </div>
                                    <div class="card-body">
                                        <p class="mb-0">@facturaVisualizacion.Observaciones</p>
                                    </div>
                                </div>
                            }

                            <!-- Documento Adjunto -->
                            @if (!string.IsNullOrEmpty(facturaVisualizacion.DocumentoAdjunto))
                            {
                                <div class="card mb-3">
                                    <div class="card-header" style="background-color: #28a745; color: white;">
                                        <h5 class="mb-0"><i class="bi bi-paperclip"></i> Documento Adjunto</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="alert alert-success mb-0" role="alert">
                                            <i class="bi bi-file-earmark-check-fill"></i> 
                                            <strong>@facturaVisualizacion.NombreDocumento</strong>
                                            <div class="mt-2">
                                                <button type="button" class="btn btn-sm btn-success" @onclick="DescargarDocumentoVer">
                                                    <i class="bi bi-download"></i> Descargar Documento
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Columna de Resumen -->
                        <div class="col-md-4">
                            <div class="card sticky-top" style="top: 20px;">
                                <div class="card-header bg-success text-white">
                                    <h5 class="mb-0"><i class="bi bi-calculator"></i> Resumen</h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Subtotal Líneas:</span>
                                        <strong>@facturaVisualizacion.Subtotal.ToString("C2")</strong>
                                    </div>
                                    @if (facturaVisualizacion.DescuentosGenerales > 0)
                                    {
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Descuentos:</span>
                                            <strong class="text-danger">-@facturaVisualizacion.DescuentosGenerales.ToString("C2")</strong>
                                        </div>
                                    }
                                    @if (facturaVisualizacion.RecargosGenerales > 0)
                                    {
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Recargos:</span>
                                            <strong class="text-success">+@facturaVisualizacion.RecargosGenerales.ToString("C2")</strong>
                                        </div>
                                    }
                                    <hr />
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Base Imponible:</span>
                                        <strong>@facturaVisualizacion.BaseImponible.ToString("C2")</strong>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>IVA:</span>
                                        <strong>@facturaVisualizacion.TotalIVA.ToString("C2")</strong>
                                    </div>
                                    @if (facturaVisualizacion.CargosAdicionales > 0)
                                    {
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Cargos Adicionales:</span>
                                            <strong>@facturaVisualizacion.CargosAdicionales.ToString("C2")</strong>
                                        </div>
                                    }
                                    @if (facturaVisualizacion.ImporteRetencion > 0)
                                    {
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Retención IRPF:</span>
                                            <strong class="text-danger">-@facturaVisualizacion.ImporteRetencion.ToString("C2")</strong>
                                        </div>
                                    }
                                    <hr />
                                    <div class="d-flex justify-content-between">
                                        <strong class="fs-5">Total:</strong>
