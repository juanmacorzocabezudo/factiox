    }

    private async Task GuardarFactura()
    {
        try
        {
            // Validaciones
            if (facturaEditando.ProveedorId == 0 || !facturaEditando.ProveedorId.HasValue)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Debe seleccionar un proveedor");
                return;
            }

            if (!facturaEditando.Lineas.Any())
            {
                await JSRuntime.InvokeVoidAsync("alert", "Debe agregar al menos una línea a la factura");
                return;
            }

            CalcularTotalModal();
            
            if (facturaEditando.Id > 0)
            {
                await FacturaService.ActualizarAsync(facturaEditando.Id, facturaEditando);
            }
            else
            {
                await FacturaService.CrearAsync(facturaEditando);
            }
            
            await CargarFacturas();
            CerrarModal();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al guardar la factura: {ex.Message}");
        }
    }

    private void OnProveedorChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int proveedorId) && proveedorId > 0)
        {
            var proveedor = proveedores?.FirstOrDefault(p => p.Id == proveedorId);
            if (proveedor != null && proveedor.FormaPago.HasValue)
            {
                facturaEditando.FormaPago = proveedor.FormaPago;
            }
        }
    }

    private void AgregarLinea()
    {
        facturaEditando.Lineas.Add(new LineaDocumento
        {
            Cantidad = 1,
            IVA = 21
        });
        CalcularTotalModal();
    }

    private void EliminarLinea(int index)
    {
        facturaEditando.Lineas.RemoveAt(index);
        CalcularTotalModal();
    }

    private void CambiarProducto(int index, int? productoId)
    {
        var linea = facturaEditando.Lineas[index];
        if (!productoId.HasValue || productoId == 0)
            return;
            
        var producto = productos?.FirstOrDefault(p => p.Id == productoId.Value);
        if (producto != null)
        {
            linea.ProductoId = producto.Id;
            linea.Producto = producto;
            linea.Descripcion = producto.Descripcion ?? producto.Nombre;
            linea.PrecioUnitario = producto.PrecioUnitario;
            linea.IVA = producto.IVA;
        }
        
        CalcularTotalModal();
    }

    private void CalcularTotalModal()
    {
        // Calcular importes de cada línea primero
        foreach (var linea in facturaEditando.Lineas)
        {
            linea.CalcularImportes();
        }
        
        // Calcular subtotal de líneas (ya se calcula automáticamente en la propiedad)
        var subtotal = facturaEditando.Subtotal;
        
        // Calcular base imponible
        facturaEditando.BaseImponible = subtotal - facturaEditando.DescuentosGenerales + facturaEditando.RecargosGenerales;
        
        // Calcular importe IVA (ya se calcula automáticamente en TotalIVA)
        facturaEditando.ImporteIVA = facturaEditando.TotalIVA;
        
        // Calcular retención
        facturaEditando.ImporteRetencion = facturaEditando.BaseImponible * (facturaEditando.PorcentajeRetencion / 100);
        
        // Calcular total
        facturaEditando.Total = facturaEditando.BaseImponible + facturaEditando.ImporteIVA + facturaEditando.CargosAdicionales - facturaEditando.ImporteRetencion;
        
        StateHasChanged();
    }

