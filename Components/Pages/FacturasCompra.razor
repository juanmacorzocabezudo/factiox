    private async Task CrearFacturaDesdeOcr()
    {
        if (facturaExtraida == null)
        {
            await JSRuntime.InvokeVoidAsync("alert", "No hay datos extraídos para crear la factura.");
            return;
        }

        if (string.IsNullOrWhiteSpace(facturaExtraida.NombreProveedor))
        {
            await JSRuntime.InvokeVoidAsync("alert", "El nombre del proveedor es obligatorio.");
            return;
        }

        if (!facturaExtraida.Lineas.Any() && !facturaExtraida.Total.HasValue)
        {
            await JSRuntime.InvokeVoidAsync("alert", "La factura debe tener al menos un total o líneas.");
            return;
        }

        guardandoOcr = true;
        try
        {
            // 1. Buscar o crear proveedor
            var proveedor = proveedores?.FirstOrDefault(p => 
                p.NIF == facturaExtraida.NifProveedor || 
                p.Nombre.Contains(facturaExtraida.NombreProveedor, StringComparison.OrdinalIgnoreCase));

            if (proveedor == null)
            {
                // Crear nuevo proveedor
                proveedor = new Proveedor
                {
                    Nombre = facturaExtraida.NombreProveedor,
                    NIF = facturaExtraida.NifProveedor,
                    Direccion = facturaExtraida.DireccionProveedor,
                    CodigoPostal = facturaExtraida.CodigoPostalProveedor,
                    Ciudad = facturaExtraida.CiudadProveedor,
                    Provincia = facturaExtraida.ProvinciaProveedor,
                    Telefono = facturaExtraida.TelefonoProveedor,
                    Email = facturaExtraida.EmailProveedor,
                    Activo = true,
                    EmpresaId = empresaId
                };
                proveedor = await ProveedorService.CrearAsync(proveedor);
            }

            // 2. Crear factura de compra
            var factura = new Factura
            {
                NumeroFactura = facturaExtraida.NumeroFactura ?? $"COMP-{DateTime.Now:yyyyMMddHHmmss}",
                TipoFactura = TipoFactura.Compra,
                FechaEmision = facturaExtraida.FechaEmision ?? DateTime.Now,
                FechaVencimiento = facturaExtraida.FechaVencimiento,
                ProveedorId = proveedor.Id,
                BaseImponible = facturaExtraida.BaseImponible.GetValueOrDefault(0),
                PorcentajeIVA = facturaExtraida.PorcentajeIVA.GetValueOrDefault(21),
                ImporteIVA = facturaExtraida.ImporteIVA.GetValueOrDefault(0),
                Total = facturaExtraida.Total.GetValueOrDefault(0),
                Estado = EstadoFactura.Emitida,
                Observaciones = facturaExtraida.Observaciones,
                EmpresaId = empresaId
            };

            // 3. Agregar líneas si existen
            if (facturaExtraida.Lineas.Any())
            {
                foreach (var lineaExtraida in facturaExtraida.Lineas)
                {
                    var ivaLinea = lineaExtraida.IVA ?? facturaExtraida.PorcentajeIVA ?? 21m;
                    factura.Lineas.Add(new LineaDocumento
                    {
                        Descripcion = lineaExtraida.Descripcion,
                        Cantidad = lineaExtraida.Cantidad,
                        PrecioUnitario = lineaExtraida.PrecioUnitario,
                        IVA = ivaLinea,
                        Descuento = lineaExtraida.Descuento.GetValueOrDefault(0),
                        Subtotal = lineaExtraida.PrecioUnitario * lineaExtraida.Cantidad,
                        Total = lineaExtraida.Total
                    });
                }
            }
            else
            {
                // Si no hay líneas, crear una línea genérica
                factura.Lineas.Add(new LineaDocumento
                {
                    Descripcion = "Factura extraída por OCR",
                    Cantidad = 1,
                    PrecioUnitario = factura.BaseImponible,
                    IVA = factura.PorcentajeIVA,
                    Descuento = 0,
                    Subtotal = factura.BaseImponible,
                    Total = factura.Total
                });
            }

            // 4. Guardar factura
            await FacturaService.CrearAsync(factura);

            await JSRuntime.InvokeVoidAsync("alert", "Factura de compra creada exitosamente.");
            CerrarModalOcr();
            await CargarFacturas();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al crear la factura: {ex.Message}");
        }
        finally
        {
            guardandoOcr = false;
        }
    }

