    private async Task CargarImagen(InputFileChangeEventArgs e)
    {
        try
        {
            var archivo = e.File;
            
            // Validar que sea una imagen y no supere 5MB
            if (!archivo.ContentType.StartsWith("image/"))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Por favor, seleccione un archivo de imagen válido.");
                return;
            }

            if (archivo.Size > 5 * 1024 * 1024) // 5MB
            {
                await JSRuntime.InvokeVoidAsync("alert", "La imagen no debe superar 5MB.");
                return;
            }

            // Leer el archivo
            using var stream = archivo.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();

            // Redimensionar y comprimir la imagen usando JavaScript
            var base64Original = Convert.ToBase64String(bytes);
            var mimeType = archivo.ContentType;
            
            // Llamar a JavaScript para redimensionar la imagen
            var base64Redimensionada = await JSRuntime.InvokeAsync<string>(
                "redimensionarImagen", 
                $"data:{mimeType};base64,{base64Original}", 
                400, // ancho máximo
                400  // alto máximo
            );

            productoActual.Imagen = base64Redimensionada;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al cargar la imagen: {ex.Message}");
        }
    }

    private void EliminarImagen()
    {
        productoActual.Imagen = null;
        StateHasChanged();
    }
