@code {
    private List<Factura>? facturas;
    private List<Cliente>? clientes;
    private List<Producto>? productos;
    private List<FormaPagoPersonalizada>? formasPago;
    private List<Empresa>? empresasAsociadas;
    private string busqueda = "";
    private string filtroEstado = "";
    private DateTime? filtroFechaDesde;
    private DateTime? filtroFechaHasta;
    private List<int> filtroEmpresaIds = new List<int>();
    private bool mostrarModal = false;
    private Factura facturaEditando = new Factura { TipoFactura = TipoFactura.Venta, Lineas = new List<LineaDocumento>() };
    
    // Modal de visualización solo lectura para Asesoría
    private bool mostrarModalVer = false;
    private Factura? facturaVisualizacion = null;
    
    // Modal de cliente
    private bool mostrarModalCliente = false;
    private Cliente clienteEditando = new Cliente();
    
    // Gestión de pagos - nuevo sistema modular
    private bool mostrarModalListaPagos = false;
    private bool mostrarModalDetallePago = false;
    private bool mostrarModalNuevoPago = false;
    private Factura? facturaParaPago;
    private Cliente? clienteSeleccionado;
    private List<PagoFactura>? pagosList;
    private PagoFactura? pagoDetalle;
    private PagoFactura nuevoPago = new PagoFactura();

    private IEnumerable<Factura> FacturasFiltradas
    {
        get
        {
            if (facturas == null) return Enumerable.Empty<Factura>();

            var resultado = facturas.AsEnumerable();

            // Filtrar por búsqueda (número o cliente)
            if (!string.IsNullOrWhiteSpace(busqueda))
            {
                resultado = resultado.Where(f =>
                    f.NumeroFactura.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
                    (f.Cliente?.Nombre?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            // Filtrar por estado
            if (!string.IsNullOrWhiteSpace(filtroEstado))
            {
                resultado = resultado.Where(f => f.Estado.ToString() == filtroEstado);
            }

            // Filtrar por fecha desde
            if (filtroFechaDesde.HasValue)
            {
                resultado = resultado.Where(f => f.FechaEmision >= filtroFechaDesde.Value);
            }

            // Filtrar por fecha hasta
            if (filtroFechaHasta.HasValue)
            {
                resultado = resultado.Where(f => f.FechaEmision <= filtroFechaHasta.Value);
            }

            // Filtrar por empresa (para Asesoría)
            if (filtroEmpresaIds.Any())
            {
                resultado = resultado.Where(f => filtroEmpresaIds.Contains(f.EmpresaId));
            }

            return resultado;
        }
    }

    private void ToggleFiltroEmpresa(int empresaId, bool seleccionado)
    {
        if (seleccionado)
        {
            if (!filtroEmpresaIds.Contains(empresaId))
            {
                filtroEmpresaIds.Add(empresaId);
            }
        }
        else
        {
            filtroEmpresaIds.Remove(empresaId);
        }
    }

    private void ToggleTodasEmpresas(bool seleccionado)
    {
        if (seleccionado)
        {
            filtroEmpresaIds.Clear();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarFacturas();
        clientes = await ClienteService.ObtenerTodosAsync();
        productos = await ProductoService.ObtenerActivosAsync();
        
        // Cargar empresas asociadas si es Asesoría
        if (AuthService.Rol == Roles.Asesoria && AuthService.EmpresaIds != null && AuthService.EmpresaIds.Any())
        {
            empresasAsociadas = new List<Empresa>();
            foreach (var empresaId in AuthService.EmpresaIds)
            {
                var empresa = await EmpresaService.ObtenerPorIdAsync(empresaId);
                if (empresa != null)
                {
                    empresasAsociadas.Add(empresa);
                }
            }
        }
        
        // Cargar formas de pago
        formasPago = await FormaPagoService.ObtenerActivosAsync();
        if (formasPago == null || !formasPago.Any())
        {
            await FormaPagoService.InicializarFormasPredefinidasAsync();
            formasPago = await FormaPagoService.ObtenerActivosAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && facturas != null && facturas.Any())
        {
            // Esperar un momento para asegurar que el DOM esté listo
            await Task.Delay(100);
            await RenderizarGraficos();
        }
    }

    private async Task RenderizarGraficos()
    {
        if (facturas == null || !facturas.Any())
        {
            Console.WriteLine("No hay facturas para renderizar gráficos");
            return;
        }

        try
        {
            Console.WriteLine($"Renderizando gráficos con {facturas.Count} facturas");
            
            // Datos para gráfico de facturas por estado
            var estadosData = new
            {
                labels = new[] { "Borrador", "Emitida", "Enviada", "Pagada", "Vencida", "Cancelada" },
                counts = new[]
                {
                    facturas.Count(f => f.Estado == EstadoFactura.Borrador),
                    facturas.Count(f => f.Estado == EstadoFactura.Emitida),
                    facturas.Count(f => f.Estado == EstadoFactura.Enviada),
                    facturas.Count(f => f.Estado == EstadoFactura.Pagada),
                    facturas.Count(f => f.Estado == EstadoFactura.Vencida),
                    facturas.Count(f => f.Estado == EstadoFactura.Cancelada)
                }
            };

            // Datos para gráfico de distribución de importes
            var importesData = new
            {
                labels = new[] { "Pagada", "Pendiente", "Vencida", "Cancelada" },
                amounts = new[]
                {
                    facturas.Where(f => f.Estado == EstadoFactura.Pagada).Sum(f => (double)f.Total),
                    facturas.Where(f => f.Estado == EstadoFactura.Emitida || f.Estado == EstadoFactura.Enviada).Sum(f => (double)f.Total),
                    facturas.Where(f => f.Estado == EstadoFactura.Vencida).Sum(f => (double)f.Total),
                    facturas.Where(f => f.Estado == EstadoFactura.Cancelada).Sum(f => (double)f.Total)
                }
            };

            Console.WriteLine($"Estados: {string.Join(", ", estadosData.counts)}");
            Console.WriteLine($"Importes: {string.Join(", ", importesData.amounts)}");
            
            await JSRuntime.InvokeVoidAsync("renderizarGraficosFacturas", estadosData, importesData);
            Console.WriteLine("Llamada a JavaScript completada");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al renderizar gráficos: {ex.Message}");
        }
    }

