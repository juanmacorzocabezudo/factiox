    private async Task Imprimir(Factura factura)
    {
        try
        {
            // Cargar factura completa con proveedor y líneas
            var facturaCompleta = await FacturaService.ObtenerPorIdAsync(factura.Id);
            
            if (facturaCompleta == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error al cargar los datos de la factura.");
                return;
            }

            // Para facturas de compra, crear un "cliente" temporal con los datos del proveedor
            Cliente? clienteTemp = null;
            if (facturaCompleta.Proveedor != null)
            {
                clienteTemp = new Cliente
                {
                    Nombre = facturaCompleta.Proveedor.Nombre,
                    NIF = facturaCompleta.Proveedor.NIF ?? "",
                    Direccion = facturaCompleta.Proveedor.Direccion,
                    Ciudad = facturaCompleta.Proveedor.Ciudad,
                    CodigoPostal = facturaCompleta.Proveedor.CodigoPostal,
                    Provincia = facturaCompleta.Proveedor.Provincia,
                    Pais = facturaCompleta.Proveedor.Pais ?? "España",
                    Telefono = facturaCompleta.Proveedor.Telefono ?? "",
                    Email = facturaCompleta.Proveedor.Email ?? ""
                };
            }
            
            if (clienteTemp == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error: La factura no tiene un proveedor asignado.");
                return;
            }

            // Obtener configuración de la empresa específica de la factura
            var config = await ConfiguracionEmpresaService.ObtenerPorEmpresaIdAsync(facturaCompleta.EmpresaId);

            // Generar el PDF para IMPRIMIR
            byte[] pdfBytes = FacturaPdfService.GenerarFacturaPdf(facturaCompleta, clienteTemp, config, paraEmail: false);

            // Convertir a Base64 y usar iframe oculto para imprimir directamente
            string base64Pdf = Convert.ToBase64String(pdfBytes);
            await JSRuntime.InvokeVoidAsync("eval", $@"
                var byteCharacters = atob('{base64Pdf}');
                var byteNumbers = new Array(byteCharacters.length);
                for (var i = 0; i < byteCharacters.length; i++) {{
                    byteNumbers[i] = byteCharacters.charCodeAt(i);
                }}
                var byteArray = new Uint8Array(byteNumbers);
                var blob = new Blob([byteArray], {{type: 'application/pdf'}});
                var url = URL.createObjectURL(blob);
                
                // Crear iframe oculto para imprimir directamente
                var iframe = document.createElement('iframe');
                iframe.style.position = 'fixed';
                iframe.style.right = '0';
                iframe.style.bottom = '0';
                iframe.style.width = '0';
                iframe.style.height = '0';
                iframe.style.border = 'none';
                iframe.src = url;
                document.body.appendChild(iframe);
                
                iframe.onload = function() {{
                    setTimeout(function() {{
                        iframe.contentWindow.focus();
                        iframe.contentWindow.print();
                    }}, 250);
                }};
            ");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al imprimir: {ex.Message}");
        }
    }

