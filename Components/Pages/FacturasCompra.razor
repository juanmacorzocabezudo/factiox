    // Métodos para manejo de documentos adjuntos
    private async Task CargarDocumento(InputFileChangeEventArgs e)
    {
        try
        {
            var archivo = e.File;
            
            // Validar tamaño (30MB máximo)
            if (archivo.Size > 30 * 1024 * 1024)
            {
                await JSRuntime.InvokeVoidAsync("alert", "El archivo es demasiado grande. Tamaño máximo: 30MB");
                return;
            }

            // Validar tipo de archivo
            var tiposPermitidos = new[] { "application/pdf", "image/jpeg", "image/jpg", "image/png", 
                                          "application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
                                          "application/vnd.ms-excel", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" };
            
            if (!tiposPermitidos.Contains(archivo.ContentType))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Tipo de archivo no permitido. Use PDF, imágenes, Word o Excel.");
                return;
            }

            // Leer el archivo
            using var stream = archivo.OpenReadStream(maxAllowedSize: 30 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();

            // Convertir a base64
            var base64 = Convert.ToBase64String(bytes);

            // Si es una imagen, intentar comprimirla
            if (archivo.ContentType.StartsWith("image/"))
            {
                try
                {
                    var dataUrl = $"data:{archivo.ContentType};base64,{base64}";
                    var comprimido = await JSRuntime.InvokeAsync<string>("redimensionarImagen", dataUrl, 1920, 1920);
                    if (!string.IsNullOrEmpty(comprimido))
                    {
                        base64 = comprimido.Split(',')[1]; // Quitar el prefijo data:image/...;base64,
                    }
                }
                catch
                {
                    // Si falla la compresión, usar el original
                }
            }

            // Guardar en la factura
            facturaEditando.DocumentoAdjunto = base64;
            facturaEditando.NombreDocumento = archivo.Name;
            facturaEditando.TipoDocumento = archivo.ContentType;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al cargar el documento: {ex.Message}");
        }
    }

    private async Task DescargarDocumento()
    {
        try
        {
            if (string.IsNullOrEmpty(facturaEditando.DocumentoAdjunto) || string.IsNullOrEmpty(facturaEditando.NombreDocumento))
            {
                await JSRuntime.InvokeVoidAsync("alert", "No hay documento adjunto para descargar");
                return;
            }

            // Escapar comillas simples en el base64 y el nombre del archivo
            var base64Escaped = facturaEditando.DocumentoAdjunto.Replace("'", "\\'");
            var nombreEscaped = facturaEditando.NombreDocumento.Replace("'", "\\'");
            var tipoEscaped = facturaEditando.TipoDocumento?.Replace("'", "\\'") ?? "application/octet-stream";

            await JSRuntime.InvokeVoidAsync("eval", 
                $@"(function() {{
                    const base64String = '{base64Escaped}';
                    const byteCharacters = atob(base64String);
                    const byteNumbers = new Array(byteCharacters.length);
                    for (let i = 0; i < byteCharacters.length; i++) {{
                        byteNumbers[i] = byteCharacters.charCodeAt(i);
                    }}
                    const byteArray = new Uint8Array(byteNumbers);
                    const blob = new Blob([byteArray], {{type: '{tipoEscaped}'}});
                    const url = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = url;
                    link.download = '{nombreEscaped}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    URL.revokeObjectURL(url);
                }})()");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al descargar el documento: {ex.Message}");
            Console.WriteLine($"Error en DescargarDocumento: {ex}");
        }
    }

