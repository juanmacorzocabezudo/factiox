@page "/facturas-compra"
@using System.IO
@using FactioX.Models
@using FactioX.Services
@inject IFacturaService FacturaService
@inject IProveedorService ProveedorService
@inject IProductoService ProductoService
@inject IConfiguracionEmpresaService ConfiguracionEmpresaService
@inject IFacturaPdfService FacturaPdfService
@inject IAuthService AuthService
@inject IExcelExportService ExcelExportService
@inject IEmpresaService EmpresaService
@inject IInvoiceOcrService InvoiceOcrService
@inject IManualOcrService ManualOcrService
@inject ITenantService TenantService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Facturas de Compra - Fact ioX</PageTitle>

<div class="container-fluid">
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-receipt-cutoff"></i> Facturas de Compra</h2>
        <div>
            @if (AuthService.Rol == Roles.Asesoria)
            {
                <button class="btn btn-success" @onclick="ExportarAExcel" disabled="@(facturas == null || !FacturasFiltradas.Any())">
                    <i class="bi bi-file-earmark-excel"></i> Exportar a Excel
                </button>
            }
            else
            {
                <button class="btn me-2" style="background-color: #5cb85c; color: white;" @onclick="AbrirModalOcr">
                    <i class="bi bi-file-earmark-image"></i> Extraer con OCR
                </button>
                <button class="btn" style="background-color: #1e7e34; color: white;" @onclick="NuevaFactura">
                    <i class="bi bi-plus-circle"></i> Nueva Factura de Compra
                </button>
            }
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <input type="text" class="form-control" placeholder="Buscar por número o cliente..." @bind="busqueda" @bind:event="oninput" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="filtroEstado">
                        <option value="">Todos los estados</option>
                        <option value="Borrador">Borrador</option>
                        <option value="Emitida">Emitida</option>
                        <option value="Enviada">Enviada</option>
                        <option value="Pagada">Pagada</option>
                        <option value="Vencida">Vencida</option>
                        <option value="Cancelada">Cancelada</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" class="form-control" @bind="filtroFechaDesde" placeholder="Fecha desde" />
                </div>
                <div class="col-md-3">
                    <input type="date" class="form-control" @bind="filtroFechaHasta" placeholder="Fecha hasta" />
                </div>
            </div>
            @if (AuthService.Rol == Roles.Asesoria)
            {
                <div class="row mt-3">
                    <div class="col-md-12">
                        <label class="form-label"><strong>Filtrar por empresas:</strong></label>
                        <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto; background-color: #f8f9fa;">
                            @if (empresasAsociadas != null && empresasAsociadas.Any())
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" 
                                           checked="@(filtroEmpresaIds.Count == 0)" 
                                           @onchange="@((ChangeEventArgs e) => ToggleTodasEmpresas((bool)e.Value!))" />
                                    <label class="form-check-label fw-bold">
                                        Todas las empresas
                                    </label>
                                </div>
                                <hr class="my-2" />
                                @foreach (var empresa in empresasAsociadas.OrderBy(e => e.NombreComercial))
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" 
                                               checked="@filtroEmpresaIds.Contains(empresa.Id)" 
                                               @onchange="@((ChangeEventArgs e) => ToggleFiltroEmpresa(empresa.Id, (bool)e.Value!))" />
                                        <label class="form-check-label">
                                            @empresa.NombreComercial
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted mb-0">No hay empresas asociadas</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (facturas == null)
    {
        <p><em>Cargando...</em></p>
    }
    else if (!facturas.Any())
    {
        <div class="alert" style="background-color: #d4edda; color: #155724; border-color: #c3e6cb;">
            <i class="bi bi-info-circle"></i> No hay facturas de venta registradas.
        </div>
    }
    else
    {
        <!-- Tabla de facturas -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Lista de Facturas</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Número</th>
                                @if (AuthService.Rol == Roles.Asesoria)
                                {
                                    <th>Empresa</th>
                                }
                                <th>Proveedor</th>
                                <th>Fecha Emisión</th>
                                <th>Vencimiento</th>
                                <th class="text-end">Base</th>
                                <th class="text-end">IVA</th>
                                <th class="text-end">Total</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var factura in FacturasFiltradas)
                            {
                                <tr class="@(factura.Estado == EstadoFactura.Vencida ? "table-warning" : "")" 
                                    @ondblclick="@(() => AbrirFactura(factura.Id))" 
                                    style="cursor: pointer;">
                                    <td><strong>@factura.NumeroFactura</strong></td>
                                    @if (AuthService.Rol == Roles.Asesoria)
                                    {
                                        <td><span class="badge bg-secondary">@factura.Empresa?.NombreComercial</span></td>
                                    }
                                    <td>@factura.Proveedor?.Nombre</td>
                                    <td>@factura.FechaEmision.ToString("dd/MM/yyyy")</td>
                                    <td>@(factura.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td class="text-end">@factura.BaseImponible.ToString("C2")</td>
                                    <td class="text-end">@factura.ImporteIVA.ToString("C2")</td>
                                    <td class="text-end"><strong>@factura.Total.ToString("C2")</strong></td>
                                    <td>
                                        <span class="badge @ObtenerClaseEstado(factura.Estado)">
                                            @factura.Estado
                                        </span>
                                    </td>
                                    <td>
                                        @if (AuthService.Rol != Roles.Asesoria)
                                        {
                                            @if (!string.IsNullOrEmpty(factura.DocumentoAdjunto))
                                            {
                                                <button class="btn btn-sm btn-outline-success me-1" @onclick="() => DescargarDocumentoListado(factura)" title="Descargar Documento">
                                                    <i class="bi bi-file-earmark-arrow-down-fill"></i>
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-outline-success me-1" @onclick="() => EnviarPorEmail(factura)" title="Enviar por Email">
                                                <i class="bi bi-envelope-fill"></i>
                                            </button>
                                            <button class="btn btn-sm me-1" style="color: #5cb85c; border-color: #5cb85c;" @onclick="() => Imprimir(factura)" title="Imprimir">
                                                <i class="bi bi-printer-fill"></i>
                                            </button>
                                            <button class="btn btn-sm me-1" style="color: #28a745; border-color: #28a745;" @onclick="() => ExportarFacturaE(factura)" title="Exportar FacturaE XML">
                                                <i class="bi bi-file-earmark-code"></i>
                                            </button>
                                            <button class="btn btn-sm me-1" style="color: #1e7e34; border-color: #1e7e34;" @onclick="() => EditarFactura(factura.Id)" title="Editar">
                                                <i class="bi bi-pencil-fill"></i>
                                            </button>
                                            <button class="btn btn-sm" style="color: #155724; border-color: #155724;" @onclick="() => EliminarFactura(factura.Id)" title="Eliminar">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="@(() => AbrirFactura(factura.Id))" title="Ver">
                                                <i class="bi bi-eye-fill"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-success me-1" @onclick="() => ImprimirListado(factura)" title="Imprimir">
                                                <i class="bi bi-printer-fill"></i>
                                            </button>
                                            @if (!string.IsNullOrEmpty(factura.DocumentoAdjunto))
                                            {
                                                <button class="btn btn-sm btn-outline-success me-1" @onclick="() => DescargarDocumentoListado(factura)" title="Descargar Documento">
                                                    <i class="bi bi-file-earmark-arrow-down-fill"></i>
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Estadísticas -->
        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5><i class="bi bi-bar-chart-fill"></i> Estadísticas</h5>
            </div>

            <div class="row">
                <div class="col-md-3">
                    <div class="card" style="background-color: #1e7e34; color: white;">
                        <div class="card-body">
                            <h6>Total Facturado</h6>
                            <h3>@facturas.Sum(f => f.Total).ToString("C2")</h3>
                            <small>@facturas.Count facturas</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <h6>Cobradas</h6>
                            <h3>@facturas.Where(f => f.Estado == EstadoFactura.Pagada).Sum(f => f.Total).ToString("C2")</h3>
                            <small>@facturas.Count(f => f.Estado == EstadoFactura.Pagada) facturas</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card" style="background-color: #a8d5ba; color: #155724;">
                        <div class="card-body">
                            <h6>Pendientes</h6>
                            <h3>@facturas.Where(f => f.Estado == EstadoFactura.Emitida || f.Estado == EstadoFactura.Enviada).Sum(f => f.Total).ToString("C2")</h3>
                            <small>@facturas.Count(f => f.Estado == EstadoFactura.Emitida || f.Estado == EstadoFactura.Enviada) facturas</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card" style="background-color: #155724; color: white;">
                        <div class="card-body">
                            <h6>Vencidas</h6>
                            <h3>@facturas.Where(f => f.Estado == EstadoFactura.Vencida).Sum(f => f.Total).ToString("C2")</h3>
                            <small>@facturas.Count(f => f.Estado == EstadoFactura.Vencida) facturas</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal para Nueva/Editar Factura -->
@if (mostrarModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #1e7e34; color: white;">
                    <h5 class="modal-title">@(facturaEditando?.Id > 0 ? "Editar" : "Nueva") Factura de Compra</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@facturaEditando" OnValidSubmit="GuardarFactura">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5>Datos de la Factura</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label for="proveedor" class="form-label">Proveedor *</label>
                                                <InputSelect id="proveedor" class="form-select" @bind-Value="facturaEditando.ProveedorId" @onchange="OnProveedorChanged">
                                                    <option value="0">Seleccione un proveedor...</option>
                                                    @if (proveedores != null && proveedores.Any())
                                                    {
                                                        @foreach (var proveedor in proveedores)
                                                        {
                                                            <option value="@proveedor.Id">@proveedor.Nombre</option>
                                                        }
                                                    }
                                                </InputSelect>
                                                @if (proveedores == null || !proveedores.Any())
                                                {
                                                    <small style="color: #7cb342;">
                                                        <i class="bi bi-exclamation-triangle"></i> No hay proveedores disponibles. <a href="/proveedores" style="color: #1e7e34;">Crear proveedor</a>
                                                    </small>
                                                }
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-3 mb-3">
                                                <label for="fecha" class="form-label">Fecha Emisión *</label>
                                                <InputDate id="fecha" class="form-control" @bind-Value="facturaEditando.FechaEmision" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="fechaVencimiento" class="form-label">Fecha Vencimiento</label>
                                                <InputDate id="fechaVencimiento" class="form-control" @bind-Value="facturaEditando.FechaVencimiento" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="fechaOperacion" class="form-label">Fecha Operación</label>
                                                <InputDate id="fechaOperacion" class="form-control" @bind-Value="facturaEditando.FechaOperacion" />
                                                <small class="text-muted">Fecha real del servicio</small>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="estado" class="form-label">Estado</label>
                                                <InputSelect id="estado" class="form-select" @bind-Value="facturaEditando.Estado">
                                                    @foreach (EstadoFactura estado in Enum.GetValues(typeof(EstadoFactura)))
                                                    {
                                                        <option value="@estado">@estado</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-3 mb-3">
                                                <label for="formaPago" class="form-label">Forma de Pago</label>
                                                <InputSelect id="formaPago" class="form-control" @bind-Value="facturaEditando.FormaPago">
                                                    <option value="">Seleccione...</option>
                                                    @foreach (var forma in Enum.GetValues<FormaPago>())
                                                    {
                                                        <option value="@forma">@forma</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="periodoInicio" class="form-label">Período Inicio</label>
                                                <InputDate id="periodoInicio" class="form-control" @bind-Value="facturaEditando.FechaPeriodoInicio" />
                                                <small class="text-muted">Para servicios periódicos</small>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label for="periodoFin" class="form-label">Período Fin</label>
                                                <InputDate id="periodoFin" class="form-control" @bind-Value="facturaEditando.FechaPeriodoFin" />
                                                <small class="text-muted">Para servicios periódicos</small>
                                            </div>
                                            @if (facturaEditando.Estado == EstadoFactura.Pagada)
                                            {
                                                <div class="col-md-3 mb-3">
                                                    <label for="fechaPago" class="form-label">Fecha de Pago</label>
                                                    <InputDate id="fechaPago" class="form-control" @bind-Value="facturaEditando.FechaPago" />
                                                </div>
                                            }
                                        </div>
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label for="concepto" class="form-label">Concepto</label>
                                                <textarea id="concepto" class="form-control" rows="2" @bind="facturaEditando.Concepto" placeholder="Descripción del servicio facturado"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-3">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5>Líneas de la Factura</h5>
                                        <button type="button" class="btn btn-sm" style="background-color: #28a745; color: white;" @onclick="AgregarLinea">
                                            <i class="bi bi-plus"></i> Agregar Línea
                                        </button>
                                    </div>
                                    <div class="card-body">
                                        @if (facturaEditando.Lineas.Any())
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 30%">Producto/Servicio</th>
                                                            <th style="width: 20%">Descripción</th>
                                                            <th style="width: 10%" class="text-end">Cant.</th>
                                                            <th style="width: 12%" class="text-end">Precio</th>
                                                            <th style="width: 10%" class="text-end">Desc. %</th>
                                                            <th style="width: 10%" class="text-end">IVA %</th>
                                                            <th style="width: 13%" class="text-end">Total</th>
                                                            <th style="width: 5%"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @for (int i = 0; i < facturaEditando.Lineas.Count; i++)
                                                        {
                                                            var index = i;
                                                            var linea = facturaEditando.Lineas[index];
                                                            <tr>
                                                                <td>
                                                                    <InputSelect class="form-select form-select-sm" Value="@linea.ProductoId" ValueChanged="@((int? value) => CambiarProducto(index, value))" ValueExpression="@(() => linea.ProductoId)">
                                                                        <option value="0">Seleccionar...</option>
                                                                        @if (productos != null)
                                                                        {
                                                                            @foreach (var producto in productos)
                                                                            {
                                                                                <option value="@producto.Id">@producto.Nombre</option>
                                                                            }
                                                                        }
                                                                    </InputSelect>
                                                                </td>
                                                                <td>
                                                                    <input type="text" class="form-control form-control-sm" @bind="linea.Descripcion" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.Cantidad" @bind:after="CalcularTotalModal" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.PrecioUnitario" @bind:after="CalcularTotalModal" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.Descuento" @bind:after="CalcularTotalModal" />
                                                                </td>
                                                                <td>
                                                                    <input type="number" step="0.01" class="form-control form-control-sm text-end" @bind="linea.IVA" @bind:after="CalcularTotalModal" />
                                                                </td>
                                                                <td class="text-end align-middle">
                                                                    @linea.Total.ToString("C2")
                                                                </td>
                                                                <td>
                                                                    <button type="button" class="btn btn-sm" style="color: #155724; border-color: #155724;" @onclick="() => EliminarLinea(index)">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                            @if (productos == null || !productos.Any())
                                            {
                                                <div class="alert mt-2 mb-0" style="background-color: #d4edda; color: #155724; border-color: #c3e6cb;">
                                                    <i class="bi bi-exclamation-triangle"></i> No hay productos disponibles. <a href="/productos" style="color: #1e7e34;">Crear producto</a>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <p class="text-muted">No hay líneas agregadas</p>
                                        }
                                    </div>
                                </div>

                                <!-- Cálculos e Importes -->
                                <div class="card mb-3">
                                    <div class="card-header" style="background-color: #1e7e34; color: white;">
                                        <h5 class="mb-0"><i class="bi bi-calculator"></i> Cálculos e Importes</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Descuentos Generales (€)</label>
                                                <input type="number" step="0.01" class="form-control" @bind="facturaEditando.DescuentosGenerales" @bind:after="CalcularTotalModal" placeholder="0.00" />
                                                <small class="text-muted">Descuentos sobre el total de la factura</small>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Recargos Generales (€)</label>
                                                <input type="number" step="0.01" class="form-control" @bind="facturaEditando.RecargosGenerales" @bind:after="CalcularTotalModal" placeholder="0.00" />
                                                <small class="text-muted">Recargos adicionales (ej: recargo de equivalencia)</small>
                                            </div>
                                        </div>
                                        
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Cargos Adicionales (€)</label>
                                                <input type="number" step="0.01" class="form-control" @bind="facturaEditando.CargosAdicionales" @bind:after="CalcularTotalModal" placeholder="0.00" />
                                                <small class="text-muted">Gastos de envío, gestión, etc.</small>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Concepto de Cargos</label>
                                                <input type="text" class="form-control" @bind="facturaEditando.ConceptoCargos" placeholder="Ej: Gastos de gestión" />
                                            </div>
                                        </div>
                                        
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Retención IRPF (%)</label>
                                                <input type="number" step="0.01" class="form-control" @bind="facturaEditando.PorcentajeRetencion" @bind:after="CalcularTotalModal" placeholder="0.00" />
                                                <small class="text-muted">Retención aplicable (opcional)</small>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Importe Retención (€)</label>
                                                <input type="number" step="0.01" class="form-control" value="@facturaEditando.ImporteRetencion.ToString("F2")" readonly style="background-color: #f8f9fa;" />
                                            </div>
                                        </div>

                                        <div class="alert mt-3" style="background-color: #d4edda; color: #155724; border-color: #c3e6cb;" role="alert">
                                            <small>
                                                <strong>Cálculo:</strong> Subtotal - Descuentos + Recargos + IVA + Cargos - Retención = <strong>@facturaEditando.Total.ToString("C2")</strong>
                                            </small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Datos para FacturaE -->
                                <div class="card mb-3">
                                    <div class="card-header" style="background-color: #5cb85c; color: white;">
                                        <h5 class="mb-0"><i class="bi bi-file-earmark-text"></i> Datos para FacturaE</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">Clase de Factura</label>
                                                <InputSelect class="form-select" @bind-Value="facturaEditando.ClaseFactura">
                                                    @foreach (var clase in Enum.GetValues<ClaseFactura>())
                                                    {
                                                        <option value="@clase">@clase</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">Tipo de Factura</label>
                                                <InputSelect class="form-select" @bind-Value="facturaEditando.TipoFactura">
                                                    @foreach (var tipo in Enum.GetValues<TipoFactura>())
                                                    {
                                                        <option value="@tipo">@tipo</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">Lugar de Expedición</label>
                                                <input type="text" class="form-control" @bind="facturaEditando.LugarExpedicion" placeholder="Ciudad" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">CP Expedición</label>
                                                <input type="text" class="form-control" @bind="facturaEditando.CodigoPostalExpedicion" placeholder="28001" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5>Observaciones</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label for="notas" class="form-label">Notas / Observaciones</label>
                                            <InputTextArea id="notas" class="form-control" rows="3" @bind-Value="facturaEditando.Observaciones" placeholder="Observaciones adicionales sobre la factura" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Documento Adjunto -->
                                <div class="card mb-3">
                                    <div class="card-header" style="background-color: #28a745; color: white;">
                                        <h5 class="mb-0"><i class="bi bi-paperclip"></i> Documento Adjunto</h5>
                                    </div>
                                    <div class="card-body">
                                        @if (!string.IsNullOrEmpty(facturaEditando.DocumentoAdjunto))
                                        {
                                            <div class="alert alert-success mb-3" role="alert">
                                                <i class="bi bi-file-earmark-check-fill"></i> 
                                                <strong>Documento adjunto:</strong> @facturaEditando.NombreDocumento
                                                <div class="mt-2">
                                                    <button type="button" class="btn btn-sm btn-success me-2" @onclick="DescargarDocumento">
                                                        <i class="bi bi-download"></i> Descargar
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-danger" @onclick="EliminarDocumento">
                                                        <i class="bi bi-trash"></i> Eliminar
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                        <div class="mb-3">
                                            <label class="form-label">Adjuntar Documento (PDF, imágenes, etc.)</label>
                                            <InputFile class="form-control" OnChange="CargarDocumento" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />
                                            <small class="text-muted">Tamaño máximo: 30MB. El archivo se comprimirá automáticamente si es posible.</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="card sticky-top" style="top: 20px;">
                                    <div class="card-header" style="background-color: #1e7e34; color: white;">
                                        <h5>Resumen</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Subtotal Líneas:</span>
                                            <strong>@facturaEditando.Subtotal.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Descuentos:</span>
                                            <strong class="text-danger">-@facturaEditando.DescuentosGenerales.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Recargos:</span>
                                            <strong class="text-success">+@facturaEditando.RecargosGenerales.ToString("C2")</strong>
                                        </div>
                                        <hr />
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Base Imponible:</span>
                                            <strong>@facturaEditando.BaseImponible.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>IVA:</span>
                                            <strong>@facturaEditando.TotalIVA.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Cargos Adicionales:</span>
                                            <strong>@facturaEditando.CargosAdicionales.ToString("C2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Retención IRPF:</span>
                                            <strong class="text-danger">-@facturaEditando.ImporteRetencion.ToString("C2")</strong>
                                        </div>
                                        <hr />
                                        <div class="d-flex justify-content-between">
                                            <strong>Total:</strong>
                                            <strong class="fs-4 text-success">@facturaEditando.Total.ToString("C2")</strong>
                                        </div>
                                        @if (facturaEditando.Id > 0)
                                        {
                                            <hr />
                                            <div class="d-flex justify-content-between mb-2">
                                                <span>Pagado:</span>
                                                <strong class="text-success">@facturaEditando.TotalPagado.ToString("C2")</strong>
                                            </div>
                                            <div class="d-flex justify-content-between">
                                                <span>Pendiente:</span>
                                                <strong class="@(facturaEditando.PendientePago > 0 ? "text-danger" : "text-success")">@facturaEditando.PendientePago.ToString("C2")</strong>
                                            </div>
                                        }
                                    </div>
                                    <div class="card-footer">
                                        <button type="submit" class="btn btn-success w-100 mb-2">
                                            <i class="bi bi-save"></i> Guardar
                                        </button>
                                        <button type="button" class="btn btn-secondary w-100" @onclick="CerrarModal">
                                            <i class="bi bi-x-circle"></i> Cancelar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<!-- Modal para Extraer Factura con OCR -->
@if (mostrarModalOcr)
{
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #5cb85c; color: white;">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-image"></i> Extraer Datos de Factura con OCR</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalOcr"></button>
                </div>
                <div class="modal-body">
                    <!-- Pestañas para seleccionar modo -->
                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(modoOcrActual == "automatico" ? "active" : "")" 
                                    type="button" 
                                    @onclick='() => CambiarModoOcr("automatico")'>
                                <i class="bi bi-magic"></i> Modo Automático (IA)
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(modoOcrActual == "manual" ? "active" : "")" 
                                    type="button" 
                                    @onclick='() => CambiarModoOcr("manual")'>
                                <i class="bi bi-cursor-fill"></i> Modo Manual (Selección)
                            </button>
                        </li>
                    </ul>

                    <!-- Contenido según el modo seleccionado -->
                    @if (modoOcrActual == "automatico")
                    {
                        <!-- MODO AUTOMÁTICO CON IA -->
                        @if (!modeloOcrDisponible)
                        {
                            <div class="alert alert-warning" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <strong>Modelo de visión no disponible</strong>
                                <p class="mb-0 mt-2">
                                    Para usar el modo automático necesitas instalar el modelo LLaVA en Ollama:
                                    <br/>
                                    <code>ollama pull llava</code>
                                    <br/>
                                    <small class="text-muted">Prueba el <strong>Modo Manual</strong> que no requiere IA</small>
                                </p>
                            </div>
                        }

                        <div class="row">
                            <!-- Columna izquierda: Upload y preview -->
                            <div class="col-md-6">
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5><i class="bi bi-upload"></i> Subir Factura</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label for="fileInputAuto" class="form-label">Selecciona una imagen de factura (JPG, PNG, PDF)</label>
                                            <InputFile id="fileInputAuto" class="form-control" OnChange="CargarArchivoOcr" accept="image/*,application/pdf" />
                                            <div class="form-text">Tamaño máximo: 3MB (recomendado: 500KB-1MB para mejores resultados)</div>
                                        </div>

                                        @if (imagenCargada)
                                        {
                                            <div class="text-center mb-3">
                                                <img src="@imagenPreview" alt="Preview factura" class="img-fluid border rounded" style="max-height: 400px;" />
                                            </div>
                                            
                                            <div class="d-grid gap-2">
                                                <button type="button" class="btn btn-primary btn-lg" @onclick="ExtraerDatosOcr" disabled="@procesandoOcr">
                                                    @if (procesandoOcr)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                                        <span>Extrayendo datos con IA...</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-magic me-2"></i>
                                                        <span>Extraer Datos Automáticamente</span>
                                                    }
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Columna derecha: Datos extraídos -->
                            <div class="col-md-6">
                                @if (facturaExtraida != null)
                                {
                                    <div class="card mb-3">
                                        <div class="card-header d-flex justify-content-between align-items-center">
                                            <h5><i class="bi bi-card-checklist"></i> Datos Extraídos</h5>
                                            @if (facturaExtraida.Confianza > 0)
                                            {
                                                <span class="badge @(facturaExtraida.Confianza >= 70 ? "bg-success" : facturaExtraida.Confianza >= 40 ? "bg-warning" : "bg-danger")">
                                                    Confianza: @facturaExtraida.Confianza%
                                                </span>
                                            }
                                        </div>
                                        <div class="card-body" style="max-height: 500px; overflow-y: auto;">
                                            @if (facturaExtraida.Advertencias.Any())
                                            {
                                                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                                                    <strong>Advertencias:</strong>
                                                    <ul class="mb-0 mt-2">
                                                        @foreach (var advertencia in facturaExtraida.Advertencias)
                                                        {
                                                            <li>@advertencia</li>
                                                        }
                                                    </ul>
                                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                                </div>
                                            }

                                            <!-- Proveedor -->
                                            <h6 class="border-bottom pb-2 mb-3">Datos del Proveedor</h6>
                                            <div class="row mb-3">
                                                <div class="col-md-8">
                                                    <label class="form-label">Nombre *</label>
                                                    <input type="text" class="form-control form-control-sm" @bind="facturaExtraida.NombreProveedor" />
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">NIF/CIF</label>
                                                    <input type="text" class="form-control form-control-sm" @bind="facturaExtraida.NifProveedor" />
                                                </div>
                                            </div>

                                            <!-- Datos de factura -->
                                            <h6 class="border-bottom pb-2 mb-3 mt-4">Datos de la Factura</h6>
                                            <div class="row mb-3">
                                                <div class="col-md-6">
                                                    <label class="form-label">Número de Factura</label>
                                                    <input type="text" class="form-control form-control-sm" @bind="facturaExtraida.NumeroFactura" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">Fecha Emisión</label>
                                                    <input type="date" class="form-control form-control-sm" @bind="facturaExtraida.FechaEmision" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label">Vencimiento</label>
                                                    <input type="date" class="form-control form-control-sm" @bind="facturaExtraida.FechaVencimiento" />
                                                </div>
                                            </div>

                                            <!-- Totales -->
                                            <h6 class="border-bottom pb-2 mb-3 mt-4">Totales</h6>
                                            <div class="row mb-3">
                                                <div class="col-md-4">
                                                    <label class="form-label">Base Imponible</label>
                                                    <input type="number" class="form-control form-control-sm" @bind="facturaExtraida.BaseImponible" step="0.01" />
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">IVA (%)</label>
                                                    <input type="number" class="form-control form-control-sm" @bind="facturaExtraida.PorcentajeIVA" step="0.01" />
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label">Total</label>
                                                    <input type="number" class="form-control form-control-sm fw-bold" @bind="facturaExtraida.Total" step="0.01" />
                                                </div>
                                            </div>

                                            <!-- Botón para crear factura -->
                                            <div class="d-grid gap-2 mt-4">
                                                <button type="button" class="btn btn-success" @onclick="CrearFacturaDesdeOcr" disabled="@guardandoOcr">
                                                    @if (guardandoOcr)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                                        <span>Creando factura...</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-check-circle me-2"></i>
                                                        <span>Crear Factura de Compra</span>
                                                    }
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else if (!imagenCargada)
                                {
                                    <div class="card">
                                        <div class="card-body text-center text-muted py-5">
                                            <i class="bi bi-image" style="font-size: 4rem;"></i>
                                            <p class="mt-3">Sube una imagen de factura para comenzar</p>
                                            <small>La IA extraerá automáticamente todos los datos</small>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- MODO MANUAL CON SELECCIÓN DE ÁREAS -->
                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Modo Manual:</strong> Dibuja rectángulos sobre cada dato de la factura para extraerlos con precisión.
                            <br/>
                            <small>1. Sube la imagen → 2. Selecciona un campo → 3. Dibuja un rectángulo sobre ese dato</small>
                        </div>

                        <div class="row">
                            <!-- Columna izquierda: Imagen y canvas -->
                            <div class="col-md-8">
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5><i class="bi bi-upload"></i> Imagen de Factura</h5>
                                    </div>
                                    <div class="card-body">
                                        @if (!imagenCargada)
                                        {
                                            <div class="mb-3">
                                                <label for="fileInputManual" class="form-label">Selecciona una imagen de factura</label>
                                                <InputFile id="fileInputManual" class="form-control" OnChange="CargarArchivoOcrManual" accept="image/*,application/pdf" />
                                            </div>
                                        }
                                        else
                                        {
                                            <!-- Canvas para dibujar áreas -->
                                            <div class="position-relative" style="overflow-x: auto;">
                                                <img id="ocr-image-source" @ref="imagenElementRef" src="@imagenPreview" style="display: none;" />
                                                <canvas id="ocr-canvas" class="border" style="max-width: 100%; cursor: crosshair;"></canvas>
                                            </div>
                                            
                                            <div class="mt-3">
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="LimpiarAreasSeleccionadas">
                                                    <i class="bi bi-trash"></i> Limpiar Todo
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="RecargarImagen">
                                                    <i class="bi bi-arrow-clockwise"></i> Cambiar Imagen
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Columna derecha: Campos y controles -->
                            <div class="col-md-4">
                                @if (imagenCargada)
                                {
                                    <div class="card mb-3">
                                        <div class="card-header bg-primary text-white">
                                            <h6 class="mb-0"><i class="bi bi-cursor-fill"></i> Seleccionar Campos</h6>
                                        </div>
                                        <div class="card-body p-2" style="max-height: 400px; overflow-y: auto;">
                                            <small class="text-muted d-block mb-2">Haz clic en un campo y luego dibuja sobre la imagen</small>
                                            <div class="d-grid gap-1" id="manual-fields-buttons">
                                                <!-- Los botones se generarán dinámicamente con JavaScript -->
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card mb-3">
                                        <div class="card-header bg-success text-white">
                                            <h6 class="mb-0"><i class="bi bi-check2-square"></i> Áreas Seleccionadas</h6>
                                        </div>
                                        <div class="card-body p-2">
                                            <ul class="list-group list-group-flush" id="selected-fields-list">
                                                <li class="list-group-item text-muted text-center">
                                                    <small>Ningún campo seleccionado aún</small>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="d-grid gap-2">
                                        <button type="button" class="btn btn-primary" @onclick="ExtraerDatosManual" disabled="@procesandoOcrManual">
                                            @if (procesandoOcrManual)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                                <span>Extrayendo...</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-arrow-right-circle me-2"></i>
                                                <span>Extraer Datos Seleccionados</span>
                                            }
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="card">
                                        <div class="card-body text-center text-muted py-5">
                                            <i class="bi bi-images" style="font-size: 3rem;"></i>
                                            <p class="mt-3 mb-0">Sube una imagen para comenzar</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModalOcr">
                        <i class="bi bi-x-circle"></i> Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<!-- Modal de Visualización Solo Lectura para Asesoría -->
@if (mostrarModalVer)
{
    <div class="modal fade show" style="display: block; z-index: 1056;" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #1e7e34; color: white;">
                    <h5 class="modal-title">
                        <i class="bi bi-eye"></i> Ver Factura de Compra @(facturaVisualizacion != null ? $"- {facturaVisualizacion.NumeroFactura}" : "")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalVer"></button>
                </div>
                <div class="modal-body">
                    @if (facturaVisualizacion != null)
                    {
                        <div class="row">
                            <div class="col-md-8">
                            <!-- Datos del Proveedor -->
                            <div class="card mb-3">
                                <div class="card-header" style="background-color: #1e7e34; color: white;">
                                    <h5 class="mb-0"><i class="bi bi-building"></i> Proveedor</h5>
                                </div>
                                <div class="card-body">
                                    @if (facturaVisualizacion.Proveedor != null)
                                    {
                                        <div class="row">
                                            <div class="col-md-6 mb-2">
                                                <strong>Nombre:</strong><br/>
                                                <span>@facturaVisualizacion.Proveedor.Nombre</span>
                                            </div>
                                            <div class="col-md-6 mb-2">
                                                <strong>NIF:</strong><br/>
                                                <span>@facturaVisualizacion.Proveedor.NIF</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(facturaVisualizacion.Proveedor.PersonaContacto))
                                            {
                                                <div class="col-md-6 mb-2">
                                                    <strong>Persona Contacto:</strong><br/>
                                                    <span>@facturaVisualizacion.Proveedor.PersonaContacto</span>
                                                </div>
                                            }
                                            <div class="col-md-6 mb-2">
                                                <strong>Email:</strong><br/>
                                                <span>@facturaVisualizacion.Proveedor.Email</span>
                                            </div>
                                            <div class="col-md-6 mb-2">
                                                <strong>Teléfono:</strong><br/>
                                                <span>@facturaVisualizacion.Proveedor.Telefono</span>
                                            </div>
                                            <div class="col-md-12 mb-2">
                                                <strong>Dirección:</strong><br/>
                                                <span>@facturaVisualizacion.Proveedor.Direccion</span><br/>
                                                <span>@facturaVisualizacion.Proveedor.CodigoPostal @facturaVisualizacion.Proveedor.Ciudad</span><br/>
                                                <span>@facturaVisualizacion.Proveedor.Provincia, @facturaVisualizacion.Proveedor.Pais</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Datos de la Factura -->
                            <div class="card mb-3">
                                <div class="card-header" style="background-color: #28a745; color: white;">
                                    <h5 class="mb-0"><i class="bi bi-file-text"></i> Datos de la Factura</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-3 mb-2">
                                            <strong>Número:</strong><br/>
                                            <span>@facturaVisualizacion.NumeroFactura</span>
                                        </div>
                                        <div class="col-md-3 mb-2">
                                            <strong>Fecha Emisión:</strong><br/>
                                            <span>@facturaVisualizacion.FechaEmision.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="col-md-3 mb-2">
                                            <strong>Fecha Vencimiento:</strong><br/>
                                            <span>@(facturaVisualizacion.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "-")</span>
                                        </div>
                                        <div class="col-md-3 mb-2">
                                            <strong>Estado:</strong><br/>
                                            <span class="badge @ObtenerClaseEstado(facturaVisualizacion.Estado)">@facturaVisualizacion.Estado</span>
                                        </div>
                                        @if (facturaVisualizacion.FechaOperacion.HasValue)
                                        {
                                            <div class="col-md-3 mb-2">
                                                <strong>Fecha Operación:</strong><br/>
                                                <span>@facturaVisualizacion.FechaOperacion?.ToString("dd/MM/yyyy")</span>
                                            </div>
                                        }
                                        @if (facturaVisualizacion.FormaPago.HasValue)
                                        {
                                            <div class="col-md-3 mb-2">
                                                <strong>Forma de Pago:</strong><br/>
                                                <span>@ObtenerNombreFormaPago(facturaVisualizacion.FormaPago.Value)</span>
                                            </div>
                                        }
