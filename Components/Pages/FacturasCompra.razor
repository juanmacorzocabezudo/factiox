    private async Task CargarArchivoOcrManual(InputFileChangeEventArgs e)
    {
        try
        {
            var archivo = e.File;
            
            // Sin límite de tamaño para modo manual
            using var ms = new MemoryStream();
            await archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
            var bytes = ms.ToArray();
            
            imagenBase64 = Convert.ToBase64String(bytes);
            imagenPreview = $"data:{archivo.ContentType};base64,{imagenBase64}";
            imagenCargada = true;
            facturaExtraida = null;
            
            // Dar tiempo para que se renderice la imagen y el canvas
            StateHasChanged();
            await Task.Delay(300);
            
            // Inicializar el selector con la nueva función dedicada
            await JSRuntime.InvokeVoidAsync("eval", @"
                setTimeout(() => {
                    if (window.ManualOcrSelector) {
                        const success = ManualOcrSelector.initializeUI(
                            'ocr-image-source',
                            'ocr-canvas',
                            'manual-fields-buttons'
                        );
                        if (!success) {
                            console.error('Error al inicializar OCR manual');
                        }
                    } else {
                        console.error('ManualOcrSelector no está disponible');
                    }
                }, 500);
            ");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al cargar el archivo: {ex.Message}");
        }
    }

    private async Task ExtraerDatosManual()
    {
        procesandoOcrManual = true;
        try
        {
            // Obtener las áreas seleccionadas del JavaScript
            var areasJson = await JSRuntime.InvokeAsync<string>("eval", "JSON.stringify(ManualOcrSelector.getAreas())");
            
            if (string.IsNullOrEmpty(areasJson) || areasJson == "{}")
            {
                await JSRuntime.InvokeVoidAsync("alert", "Selecciona al menos un área en la imagen");
                return;
            }

            // Verificar campos requeridos
            var missingFields = await JSRuntime.InvokeAsync<string>("eval", 
                "JSON.stringify(ManualOcrSelector.getMissingFields())");
            
            if (!string.IsNullOrEmpty(missingFields) && missingFields != "[]")
            {
                var confirm = await JSRuntime.InvokeAsync<bool>("confirm", 
                    $"Faltan campos requeridos. ¿Deseas continuar de todos modos?");
                if (!confirm) return;
            }

            // Parsear las áreas
            var areas = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, Dictionary<string, int>>>(areasJson);
            if (areas == null || !areas.Any())
            {
                await JSRuntime.InvokeVoidAsync("alert", "No se pudieron procesar las áreas seleccionadas");
                return;
            }

            // Convertir a Dictionary<string, Rectangle>
            var areasRect = new Dictionary<string, System.Drawing.Rectangle>();
            foreach (var area in areas)
            {
                if (area.Value.ContainsKey("x") && area.Value.ContainsKey("y") && 
                    area.Value.ContainsKey("width") && area.Value.ContainsKey("height"))
                {
                    areasRect[area.Key] = new System.Drawing.Rectangle(
                        area.Value["x"],
                        area.Value["y"],
                        area.Value["width"],
                        area.Value["height"]
                    );
                }
            }

            // Extraer datos con el servicio manual
            facturaExtraida = await ManualOcrService.ExtraerDatosDeAreasAsync(imagenBase64, areasRect);
            
            if (facturaExtraida != null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Datos extraídos correctamente. Revisa y corrige los campos si es necesario.");
                
                // Cambiar a modo automático para mostrar los datos extraídos
                modoOcrActual = "automatico";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al extraer datos: {ex.Message}");
        }
        finally
        {
            procesandoOcrManual = false;
        }
    }

