    private string ObtenerNombreFormaPago(FormaPago formaPago)
    {
        // Usar los atributos Display si existen, sino el nombre del enum
        var tipo = typeof(FormaPago);
        var memInfo = tipo.GetMember(formaPago.ToString());
        
        if (memInfo.Length > 0)
        {
            var attrs = memInfo[0].GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false);
            if (attrs.Length > 0)
            {
                var displayAttr = (System.ComponentModel.DataAnnotations.DisplayAttribute)attrs[0];
                return displayAttr.Name ?? formaPago.ToString();
            }
        }
        
        return formaPago.ToString();
    }
